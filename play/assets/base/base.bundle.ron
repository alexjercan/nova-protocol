        // The base mod's WORLD sound effects (task 20260717-002228; ownership
        // split in spike 20260717-101524). Base content references
        // `turret_fire.wav` via `self://sounds/...` (the turret section's authorable
        // `fire_sound`); the rest are played by the game's cue observers (the
        // transitional WorldSfx bank) until their families migrate onto section/
        // object configs. Listed here so mods can reference any of them via
        // `dep://base/sounds/<name>.wav`. UI/interface sounds (menu clicks,
        // objective chimes) are engine chrome like `icons/` and live at the
        // asset root, NOT here.
        "sounds/dry_fire.wav",
        "sounds/explosion.wav",
        "sounds/impact.wav",
        "sounds/lock_off.wav",
        "sounds/lock_on.wav",
        "sounds/radar_deny.wav",
        "sounds/radar_retarget.wav",
        "sounds/rcs_loop.wav",
        "sounds/safety_on.wav",
        "sounds/salvage_pickup.wav",
        "sounds/thruster_loop.wav",
        "sounds/torpedo_launch.wav",
        "sounds/turret_fire.wav",
    ],
    meta: (
        name: "Base Game",
        description: "Nova Protocol - the core sections, ships and scenarios.",
        author: "Nova Protocol",
    ),
    // The New Game start. Honored ONLY from the base bundle; the merge warns
    // and ignores it on any other bundle (mods cannot redirect New Game).
    new_game_scenario: Some("shakedown_run"),
)
