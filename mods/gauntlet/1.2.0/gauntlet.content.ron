                    // Act 2 begins: the belt closes in.
                    SetSkybox((cubemap: "dep://base/textures/cubemap_alt.png")),
                ],
            ),
            (
                name: OnEnter,
                filters: [
                    Entity((
                        id: Some("gauntlet_gate_3"),
                        other_id: Some("player_spaceship"),
                    )),
                    Expression((Equal(
                        Term(Factor(Name("gate"))),
                        Term(Factor(Literal(Number(3.0)))),
                    ))),
                ],
                actions: [
                    ObjectiveComplete((id: "gate_3")),
                    VariableSet((
                        key: "gate",
                        expression: Term(Factor(Literal(Number(4.0)))),
                    )),
                    ObjectiveMarkerDetach((target_id: "gauntlet_gate_3")),
                    ObjectiveMarkerAttach((target_id: "gauntlet_gate_4", label: "GATE 4")),
                    Objective((
                        id: "gate_4",
                        message: "GATE 4 - tight left through the debris. Hold your line.",
                    )),
                ],
            ),
            (
                name: OnEnter,
                filters: [
                    Entity((
                        id: Some("gauntlet_gate_4"),
                        other_id: Some("player_spaceship"),
                    )),
                    Expression((Equal(
                        Term(Factor(Name("gate"))),
                        Term(Factor(Literal(Number(4.0)))),
                    ))),
                ],
                actions: [
                    ObjectiveComplete((id: "gate_4")),
                    VariableSet((
                        key: "gate",
                        expression: Term(Factor(Literal(Number(5.0)))),
                    )),
                    ObjectiveMarkerDetach((target_id: "gauntlet_gate_4")),
                    ObjectiveMarkerAttach((target_id: "gauntlet_gate_5", label: "GATE 5")),
                    Objective((
                        id: "gate_5",
                        message: "GATE 5 ahead - and a planetoid's pull off to port. Sling or avoid.",
                    )),
                    // Act 3 begins: the hazard field.
                    SetSkybox((cubemap: "dep://base/textures/cubemap_alt.png")),
                ],
            ),
            (
                name: OnEnter,
                filters: [
                    Entity((
                        id: Some("gauntlet_gate_5"),
                        other_id: Some("player_spaceship"),
                    )),
                    Expression((Equal(
                        Term(Factor(Name("gate"))),
                        Term(Factor(Literal(Number(5.0)))),
                    ))),
                ],
                actions: [
                    ObjectiveComplete((id: "gate_5")),
                    VariableSet((
                        key: "gate",
                        expression: Term(Factor(Literal(Number(6.0)))),
                    )),
                    ObjectiveMarkerDetach((target_id: "gauntlet_gate_5")),
                    ObjectiveMarkerAttach((target_id: "gauntlet_gate_6", label: "GATE 6")),
                    Objective((
                        id: "gate_6",
                        message: "GATE 6 - break hard around the well's pull.",
                    )),
                ],
            ),
            (
                name: OnEnter,
                filters: [
                    Entity((
                        id: Some("gauntlet_gate_6"),
                        other_id: Some("player_spaceship"),
                    )),
                    Expression((Equal(
                        Term(Factor(Name("gate"))),
                        Term(Factor(Literal(Number(6.0)))),
                    ))),
                ],
                actions: [
                    ObjectiveComplete((id: "gate_6")),
                    VariableSet((
                        key: "gate",
                        expression: Term(Factor(Literal(Number(7.0)))),
                    )),
                    ObjectiveMarkerDetach((target_id: "gauntlet_gate_6")),
                    ObjectiveMarkerAttach((target_id: "gauntlet_finish", label: "FINISH")),
                    Objective((
                        id: "finish",
                        message: "Home stretch - cross the FINISH gate.",
                    )),
                ],
            ),
            (
                name: OnEnter,
                filters: [
                    Entity((
                        id: Some("gauntlet_finish"),
                        other_id: Some("player_spaceship"),
                    )),
                    Expression((Equal(
                        Term(Factor(Name("gate"))),
                        Term(Factor(Literal(Number(7.0)))),
                    ))),
                ],
                actions: [
                    ObjectiveComplete((id: "finish")),
                    ObjectiveMarkerDetach((target_id: "gauntlet_finish")),
                    HintEmphasisClear((verb: "GOTO")),
                    // Terminal: bump past the last gate so no OnEnter re-fires
                    // AND the player-death Defeat handler (gated gate < 8) can
                    // never flip an earned Victory to Defeat.
                    VariableSet((
                        key: "gate",
                        expression: Term(Factor(Literal(Number(8.0)))),
                    )),
                    Objective((
                        id: "course_done",
                        message: "Course complete - clean flying, pilot.",
                    )),
                    Outcome((
                        outcome: Victory,
                        message: Some("You ran the gauntlet clean. The belt keeps its rocks; you keep your paint."),
                    )),
                ],
            ),
            // Wreck out on the rocks (or the well) before FINISH: Defeat + Retry.
            // Gated gate < 8 so a death AFTER the win declares nothing.
            (
                name: OnDestroyed,
                filters: [
                    Entity((
                        id: Some("player_spaceship"),
                    )),
                    Expression((LessThan(
                        Term(Factor(Name("gate"))),
                        Term(Factor(Literal(Number(8.0)))),
                    ))),
                ],
                actions: [
                    Outcome((
                        outcome: Defeat,
                        message: Some("You wore your hull down to nothing on the belt. Line it up and run it again."),
                    )),
                    NextScenario((
                        scenario_id: "gauntlet_run",
                        linger: true,
                    )),
                ],
            ),
        ],
    )),
]
