                    // Race state: `gate` is the index of the gate to thread next
                    // (1..=7; 7 is FINISH, 8 is the terminal done-state). Each
                    // gate's OnEnter is guarded on it, so gates cross IN ORDER.
                    VariableSet((
                        key: "gate",
                        expression: Term(Factor(Literal(Number(1.0)))),
                    )),
                    Objective((
                        id: "gate_1",
                        message: "Thread GATE 1. Hold [W] to burn, tap [G] to GOTO the marked gate.",
                    )),
                    ObjectiveMarkerAttach((
                        target_id: "gauntlet_gate_1",
                        label: "GATE 1",
                    )),
                    HintEmphasisSet((
                        verb: "GOTO",
                    )),
                ],
