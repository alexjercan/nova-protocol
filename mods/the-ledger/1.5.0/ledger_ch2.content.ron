            ),
            // The teach beat, clock-spaced off the opening line (one line per
            // beat - the beat-sheet convention): eight seconds after the
            // contact call, while the arrivals are still inbound.
            (
                name: OnUpdate,
                filters: [
                    Expression((GreaterThan(
                        Term(Factor(Name("scenario_elapsed"))),
                        Term(Factor(Literal(Number(8.0)))),
                    ))),
                    Expression((Equal(
                        Term(Factor(Name("teach_sent"))),
                        Term(Factor(Literal(Number(0.0)))),
                    ))),
                    Expression((Equal(
                        Term(Factor(Name("act"))),
                        Term(Factor(Literal(Number(1.0)))),
                    ))),
                ],
                actions: [
                    VariableSet((
                        key: "teach_sent",
                        expression: Term(Factor(Literal(Number(1.0)))),
                    )),
                    StoryMessage((
                        speaker: "Foreman Okono",
                        text: "They only have eyes for you, not the Mule - so drag their fire wide of her, and keep a rock between you when the tracers come.",
                    )),
                ],
            ),
            // --- Wave-one kills. ---
            (
                name: OnDestroyed,
                filters: [
                    Entity((
                        id: Some("magpie_1"),
                    )),
                    Expression((Equal(
                        Term(Factor(Name("act"))),
                        Term(Factor(Literal(Number(1.0)))),
                    ))),
                ],
                actions: [
                    VariableSet((
                        key: "kills",
                        expression: Add(Factor(Name("kills")), Term(Factor(Literal(Number(1.0))))),
                    )),
                    StoryMessage((
                        speaker: "Foreman Okono",
                        text: "Sixpence is scrap. Don't cheer yet.",
                    )),
                ],
            ),
            (
                name: OnDestroyed,
                filters: [
                    Entity((
                        id: Some("magpie_2"),
                    )),
                    Expression((Equal(
                        Term(Factor(Name("act"))),
                        Term(Factor(Literal(Number(1.0)))),
                    ))),
                ],
                actions: [
                    VariableSet((
                        key: "kills",
                        expression: Add(Factor(Name("kills")), Term(Factor(Literal(Number(1.0))))),
                    )),
                    StoryMessage((
                        speaker: "Foreman Okono",
                        text: "Tinfoil King's down. The Mule's still breathing.",
                    )),
                ],
            ),
            // Wave one broken -> the checkpoint beat. The chapter
            // continues in ledger_ch2b (The Heavies); dying there retries
            // there, not here - that split IS the checkpoint.
            (
                name: OnUpdate,
                filters: [
                    Expression((Equal(
                        Term(Factor(Name("act"))),
                        Term(Factor(Literal(Number(1.0)))),
                    ))),
                    Expression((GreaterThan(
                        Term(Factor(Name("kills"))),
                        Term(Factor(Literal(Number(1.0)))),
                    ))),
                ],
                actions: [
                    VariableSet((
                        key: "act",
                        expression: Term(Factor(Literal(Number(2.0)))),
                    )),
                    ObjectiveComplete((
                        id: "obj_wave",
                    )),
                    ObjectiveComplete((
                        id: "obj_escort",
                    )),
                    Outcome((
                        outcome: Victory,
                        message: Some("Wave one broken. Catch your breath while you can - the Mule holds station, and the scope already shows two more burns. The Magpies are angry now."),
                    )),
                    NextScenario((
                        scenario_id: "ledger_ch2b_the_heavies",
                        linger: true,
                    )),
                ],
            ),
            // Losing the Mule loses the wave, any act before the win.
            (
                name: OnDestroyed,
                filters: [
                    Entity((
                        id: Some("dray_mule"),
                    )),
                    Expression((LessThan(
                        Term(Factor(Name("act"))),
                        Term(Factor(Literal(Number(2.0)))),
                    ))),
                ],
                actions: [
                    Outcome((
                        outcome: Defeat,
                        message: Some("The Dray Mule breaks apart - the box, the quota, the job, all of it gone."),
                    )),
                    NextScenario((
                        scenario_id: "ledger_ch2_claim_jumpers",
                        linger: true,
                    )),
                ],
            ),
            (
                name: OnDestroyed,
                filters: [
                    Entity((
                        id: Some("player_spaceship"),
                    )),
                    Expression((LessThan(
                        Term(Factor(Name("act"))),
                        Term(Factor(Literal(Number(2.0)))),
                    ))),
                ],
                actions: [
                    Outcome((
                        outcome: Defeat,
                        message: Some("The Magpies pick the Kestrel clean and tow the box away whistling."),
                    )),
                    NextScenario((
                        scenario_id: "ledger_ch2_claim_jumpers",
                        linger: true,
                    )),
                ],
            ),
        ],
    )),
]
