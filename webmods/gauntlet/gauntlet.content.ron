// Gauntlet Run content: one NEW scenario (no base overrides) - a playable
// slalom race. Spawns a player ship at the START, then guides the pilot gate
// by gate (objective + gold marker) through GATE 1 -> GATE 2 -> FINISH. A
// `gate` counter variable gates each area's OnEnter so the gates must be
// threaded IN ORDER; crossing FINISH shows a completion objective.
// Pure data-driven RON (no engine changes); `base` is an implicit dependency
// for the section prototypes the player ship is built from.
//
// INVARIANT: the gate trigger areas must not overlap. Advancing `gate` only
// arms the next gate's handler; the pilot still has to produce a fresh OnEnter
// on that next area. If two gate areas overlapped, a pilot already loitering
// inside the next area when it goes live would get no re-enter event and the
// race would soft-lock. Today the gates are ~90-140u apart with 25-30u radii,
// so this holds - keep it that way when repositioning gates.
[
    Scenario((
        id: "gauntlet_run",
        name: "Gauntlet Run",
        description: "A slalom race: thread the beacon gates in order, START to FINISH.",
        cubemap: "textures/cubemap.png",
        // A 2D image: a UI thumbnail must NOT be the skybox cubemap (that Image
        // is reinterpreted to a Cube texture, which the UI pipeline cannot bind).
        thumbnail: Some("textures/asteroid.png"),
        events: [
            (
                name: OnStart,
                filters: [],
                actions: [
                    DebugMessage((
                        message: "Gauntlet Run loaded from the mod portal.",
                    )),
                    // The racer. Same section layout as the base player ship,
                    // but with all verbs enabled (no DisableVerb): the pilot
                    // can GOTO/lock the gates from the first second.
                    SpawnScenarioObject((
                        base: (
                            id: "player_spaceship",
                            name: "Player Spaceship",
                            position: (0.0, 0.0, 0.0),
                            rotation: (0.0, 0.0, 0.0, 1.0),
                        ),
                        kind: Spaceship((
                            controller: Player((
                                input_mapping: {
                                    "turret": [
                                        Mouse(Left),
                                        Gamepad(RightTrigger2),
                                    ],
                                },
                                speed_cap: Some(25.0),
                                infinite_ammo: true,
                            )),
                            sections: [
                                (
                                    id: "controller",
                                    position: (0.0, 0.0, 0.0),
                                    rotation: (0.0, 0.0, 0.0, 1.0),
                                    source: Prototype("basic_controller_section"),
                                ),
                                (
                                    id: "hull_front",
                                    position: (0.0, 0.0, 1.0),
                                    rotation: (0.0, 0.0, 0.0, 1.0),
                                    source: Prototype("reinforced_hull_section"),
                                ),
                                (
                                    id: "thruster",
                                    position: (0.0, 0.0, 2.0),
                                    rotation: (0.0, 0.0, 0.0, 1.0),
                                    source: Prototype("basic_thruster_section"),
                                ),
                                (
                                    id: "turret",
                                    position: (0.0, 0.0, -1.0),
                                    rotation: (-0.70710677, 0.0, 0.0, 0.70710677),
                                    source: Prototype("better_turret_section"),
                                ),
                            ],
                        )),
                    )),
                    SpawnScenarioObject((
                        base: (
                            id: "gauntlet_start",
                            name: "Gauntlet Start",
                            position: (0.0, 0.0, -40.0),
                            rotation: (0.0, 0.0, 0.0, 1.0),
                        ),
                        kind: Beacon((
                            label: "START",
                            radius: 2.0,
                            color: Srgba((
                                red: 0.2,
                                green: 1.0,
                                blue: 0.4,
                                alpha: 1.0,
                            )),
                            area_radius: Some(25.0),
                            lock_signature: None,
                        )),
                    )),
                    SpawnScenarioObject((
                        base: (
                            id: "gauntlet_gate_1",
                            name: "Gauntlet Gate 1",
                            position: (35.0, 10.0, -110.0),
                            rotation: (0.0, 0.0, 0.0, 1.0),
                        ),
                        kind: Beacon((
                            label: "GATE 1",
                            radius: 2.0,
                            color: Srgba((
                                red: 1.0,
                                green: 0.8,
                                blue: 0.2,
                                alpha: 1.0,
                            )),
                            area_radius: Some(25.0),
                            lock_signature: None,
                        )),
                    )),
                    SpawnScenarioObject((
                        base: (
                            id: "gauntlet_gate_2",
                            name: "Gauntlet Gate 2",
                            position: (-30.0, -15.0, -180.0),
                            rotation: (0.0, 0.0, 0.0, 1.0),
                        ),
                        kind: Beacon((
                            label: "GATE 2",
                            radius: 2.0,
                            color: Srgba((
                                red: 1.0,
                                green: 0.8,
                                blue: 0.2,
                                alpha: 1.0,
                            )),
                            area_radius: Some(25.0),
                            lock_signature: None,
                        )),
                    )),
                    SpawnScenarioObject((
                        base: (
                            id: "gauntlet_finish",
                            name: "Gauntlet Finish",
                            position: (10.0, 5.0, -250.0),
                            rotation: (0.0, 0.0, 0.0, 1.0),
                        ),
                        kind: Beacon((
                            label: "FINISH",
                            radius: 2.5,
                            color: Srgba((
                                red: 1.0,
                                green: 0.3,
                                blue: 0.3,
                                alpha: 1.0,
                            )),
                            area_radius: Some(30.0),
                            lock_signature: None,
                        )),
                    )),
                    // Race state: `gate` is the index of the gate to thread
                    // next (1..=3). Each gate's OnEnter is guarded on it, so the
                    // gates must be crossed IN ORDER.
                    VariableSet((
                        key: "gate",
                        expression: Term(Factor(Literal(Number(1.0)))),
                    )),
                    Objective((
                        id: "gate_1",
                        message: "Thread GATE 1. Hold [W] to burn, tap [G] to GOTO the marked gate.",
                    )),
                    ObjectiveMarkerAttach((
                        target_id: "gauntlet_gate_1",
                        label: "GATE 1",
                    )),
                    HintEmphasisSet((
                        verb: "GOTO",
                    )),
                ],
            ),
            (
                name: OnEnter,
                filters: [
                    Entity((
                        id: Some("gauntlet_gate_1"),
                        other_id: Some("player_spaceship"),
                    )),
                    Expression((Equal(
                        Term(Factor(Name("gate"))),
                        Term(Factor(Literal(Number(1.0)))),
                    ))),
                ],
                actions: [
                    ObjectiveComplete((
                        id: "gate_1",
                    )),
                    VariableSet((
                        key: "gate",
                        expression: Term(Factor(Literal(Number(2.0)))),
                    )),
                    ObjectiveMarkerDetach((
                        target_id: "gauntlet_gate_1",
                    )),
                    ObjectiveMarkerAttach((
                        target_id: "gauntlet_gate_2",
                        label: "GATE 2",
                    )),
                    Objective((
                        id: "gate_2",
                        message: "Thread GATE 2. It is off to your other side - steer through it.",
                    )),
                ],
            ),
            (
                name: OnEnter,
                filters: [
                    Entity((
                        id: Some("gauntlet_gate_2"),
                        other_id: Some("player_spaceship"),
                    )),
                    Expression((Equal(
                        Term(Factor(Name("gate"))),
                        Term(Factor(Literal(Number(2.0)))),
                    ))),
                ],
                actions: [
                    ObjectiveComplete((
                        id: "gate_2",
                    )),
                    VariableSet((
                        key: "gate",
                        expression: Term(Factor(Literal(Number(3.0)))),
                    )),
                    ObjectiveMarkerDetach((
                        target_id: "gauntlet_gate_2",
                    )),
                    ObjectiveMarkerAttach((
                        target_id: "gauntlet_finish",
                        label: "FINISH",
                    )),
                    Objective((
                        id: "finish",
                        message: "Home stretch - cross the FINISH gate.",
                    )),
                ],
            ),
            (
                name: OnEnter,
                filters: [
                    Entity((
                        id: Some("gauntlet_finish"),
                        other_id: Some("player_spaceship"),
                    )),
                    Expression((Equal(
                        Term(Factor(Name("gate"))),
                        Term(Factor(Literal(Number(3.0)))),
                    ))),
                ],
                actions: [
                    ObjectiveComplete((
                        id: "finish",
                    )),
                    ObjectiveMarkerDetach((
                        target_id: "gauntlet_finish",
                    )),
                    HintEmphasisClear((
                        verb: "GOTO",
                    )),
                    // Bump past the last gate so no OnEnter re-fires.
                    VariableSet((
                        key: "gate",
                        expression: Term(Factor(Literal(Number(4.0)))),
                    )),
                    Objective((
                        id: "course_done",
                        message: "Course complete - nice flying, pilot.",
                    )),
                ],
            ),
        ],
    )),
]
