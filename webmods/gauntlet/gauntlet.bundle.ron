// The first PORTAL mod (task 20260715-142900): published to the static mod
// portal by nova_portal_gen, NOT shipped in the game's assets. Same bundle
// shape as any mod - a manifest listing content files (relative to this
// folder) plus a `meta` self-description; the generator copies this folder to
// site/mods/gauntlet/<version>/ and lists it in catalog.json.
(
    content: ["gauntlet.content.ron"],
    meta: (
        name: "Gauntlet Run",
        description: "A parkour course: thread six gates through asteroid slaloms and a gravity well, START to FINISH. Fly clean or wreck.",
        author: "Nova Protocol",
        version: "1.2.0",
        // base ALONE: the racer's sections and the course textures all live in
        // base. v1.0.0 also depended on "demo", which silently overrode
        // reinforced_hull_section's health 200 -> 400 and forced players to
        // enable the demo arena. 2.0 drops that coupling: the crash tolerance is
        // base's honest 200-health hull (tuned by playtest), and the mod no
        // longer rides a scenario slated for removal (task 20260716-155816).
        dependencies: ["base"],
    ),
)
