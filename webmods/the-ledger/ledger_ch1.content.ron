// The Ledger, chapter 1 of 4: DEAD WEIGHT (task 20260716-123535, spike
// 20260716-183104). The fantasy tutorial: strip a dead freighter for a
// three-crate quota, then the job turns - the fourth ping is a sealed
// military black box nobody logged. Mechanics are the shipped patterns:
// act-gated salvage OnEnter counting (shakedown), per-crate objectives with
// markers, a Neutral patrol ship as set dressing (broadside), Victory ->
// NextScenario chain and player-death Defeat + retry (broadside).
//
// Acts: 1 = quota run, 2 = the black box ping, 3 = resolved (victory beat).
// Every handler is act-gated except the player-death Defeat, which is the
// deliberate global exception - gated to act < 3 so a post-victory death
// cannot overwrite an earned win (the broadside act-gating lesson).
[
    Scenario((
        id: "ledger_ch1_dead_weight",
        name: "The Ledger 1: Dead Weight",
        description: "Mesa Verde Reclamation contract 4471: strip the freighter Ceres Matron for a three-crate quota. Chapter one of The Ledger.",
        cubemap: "dep://base/textures/cubemap.png",
        thumbnail: Some("dep://base/textures/asteroid.png"),
        events: [
            (
                name: OnStart,
                filters: [],
                actions: [
                    VariableSet((
                        key: "act",
                        expression: Term(Factor(Literal(Number(1.0)))),
                    )),
                    VariableSet((
                        key: "crates",
                        expression: Term(Factor(Literal(Number(0.0)))),
                    )),
                    // Opening-conversation sequencer (the Shakedown idiom):
                    // open_step walks the briefing lines on the scenario
                    // clock; quota_posted is the one-shot hand-off that lazy-
                    // posts the first crate objective; beat_gate/setup_last
                    // drive the between-pickup breathers. All seeded here - an
                    // undefined gate fails closed forever.
                    VariableSet((
                        key: "open_step",
                        expression: Term(Factor(Literal(Number(0.0)))),
                    )),
                    VariableSet((
                        key: "quota_posted",
                        expression: Term(Factor(Literal(Number(0.0)))),
                    )),
                    VariableSet((
                        key: "beat_gate",
                        expression: Term(Factor(Literal(Number(0.0)))),
                    )),
                    VariableSet((
                        key: "setup_last",
                        expression: Term(Factor(Literal(Number(0.0)))),
                    )),
                    // Per-crate breather gates + one-shot said flags (seeded
                    // 0: the delayed ack handlers gate on gate > 0, so an
                    // un-stamped crate never speaks).
                    VariableSet((
                        key: "ack1_gate",
                        expression: Term(Factor(Literal(Number(0.0)))),
                    )),
                    VariableSet((
                        key: "ack2_gate",
                        expression: Term(Factor(Literal(Number(0.0)))),
                    )),
                    VariableSet((
                        key: "ack3_gate",
                        expression: Term(Factor(Literal(Number(0.0)))),
                    )),
                    VariableSet((
                        key: "ack1_said",
                        expression: Term(Factor(Literal(Number(0.0)))),
                    )),
                    VariableSet((
                        key: "ack2_said",
                        expression: Term(Factor(Literal(Number(0.0)))),
                    )),
                    VariableSet((
                        key: "ack3_said",
                        expression: Term(Factor(Literal(Number(0.0)))),
                    )),
                    // The 4th-ping reveal breather gate + one-shot (seeded 0).
                    VariableSet((
                        key: "ping_gate",
                        expression: Term(Factor(Literal(Number(0.0)))),
                    )),
                    VariableSet((
                        key: "ping_said",
                        expression: Term(Factor(Literal(Number(0.0)))),
                    )),
                    // The objectives panel stays EMPTY through the opening
                    // conversation; this HOLDING line is all that shows until
                    // the briefing hands off to the first crate (beat sheet:
                    // no objective shares a frame with a conversation).
                    Objective((
                        id: "obj_ch1_recap",
                        message: "Ch.1 - Dead Weight: stand by for the work order.",
                    )),
                    // The tug: the gauntlet player loadout (turret included -
