                    )),
                    // The wreck: two dead hull masses, invulnerable set
                    // dressing (nothing in this chapter should pop the stage).
                    // Nominal radius is NOT the visible size: the asteroid
                    // noise mesh reaches ASTEROID_GEOMETRIC_FACTOR_MIN..MAX
                    // (3.5..6.0) past the nominal sphere, so the real hull is
                    // radius * ~6 at worst. These stay small (real ~7..12u) so
                    // the quota crates 15..16u out never end up buried inside
                    // the rock, AND so they stay under min_well_radius (5.0) -
                    // a bigger nominal would silently make each wreck a gravity
                    // well that tugs the tug across the whole work site.
                    SpawnScenarioObject((
                        base: (
                            id: "matron_bow",
                            name: "Ceres Matron - Bow Section",
                            position: (0.0, 0.0, -80.0),
                            rotation: (0.0, 0.0, 0.0, 1.0),
                        ),
                        kind: Asteroid((
                impact_sound: Some("dep://base/sounds/impact.wav"),
                destroy_sound: Some("dep://base/sounds/explosion.wav"),
