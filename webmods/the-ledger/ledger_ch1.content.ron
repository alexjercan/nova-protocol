                    )),
                    // Loose debris for depth, outside the work site.
                    ScatterObjects((
                        id_prefix: "ledger_debris_",
                        count: 10,
                        seed: 4471,
                        region: Ring(
                            inner: 150.0,
                            outer: 210.0,
                            y_min: -50.0,
                            y_max: 10.0,
                        ),
                        template: (
                            base: (
                                id: "ledger_debris_",
                                name: "Debris",
                                position: (0.0, 0.0, 0.0),
                                rotation: (0.0, 0.0, 0.0, 1.0),
                            ),
                            kind: Asteroid((
                impact_sound: Some("dep://base/sounds/impact.wav"),
                destroy_sound: Some("dep://base/sounds/explosion.wav"),
                                radius: 1.0,
                                texture: "dep://base/textures/asteroid.png",
                                health: 100.0,
                                surface_gravity: None,
                                invulnerable: false,
                                lock_signature: None,
                            )),
                        ),
                        asteroid_radius: Some((0.8, 2.0)),
                    )),
                ],
            ),
            // --- Opening conversation (the Shakedown idiom): Okono briefs
            // over the scenario clock, one line per handler/beat, spaced
            // ~9s apart. The objectives panel holds on the stand-by line the
            // whole time; the first crate objective lazy-posts only when the
            // briefing hands off (open_step == 4 below), so a blind burn
            // cannot start the quota before it is called. ---
            (
                name: OnUpdate,
                filters: [
                    Expression((Equal(
                        Term(Factor(Name("open_step"))),
                        Term(Factor(Literal(Number(0.0)))),
                    ))),
                    Expression((GreaterThan(
                        Term(Factor(Name("scenario_elapsed"))),
                        Term(Factor(Literal(Number(2.0)))),
                    ))),
                ],
                actions: [
                    VariableSet((
                        key: "open_step",
                        expression: Term(Factor(Literal(Number(1.0)))),
                    )),
                    StoryMessage((
                        speaker: "Foreman Okono",
                        text: "Kestrel, the Ceres Matron's yours. She died out here three weeks back - reactor scrammed, crew lifted off, and nobody's been back since.",
                        dwell: Some(7.0),
                    )),
                ],
            ),
            (
                name: OnUpdate,
                filters: [
                    Expression((Equal(
                        Term(Factor(Name("open_step"))),
                        Term(Factor(Literal(Number(1.0)))),
                    ))),
                    Expression((GreaterThan(
                        Term(Factor(Name("scenario_elapsed"))),
                        Term(Factor(Literal(Number(11.0)))),
                    ))),
                ],
                actions: [
                    VariableSet((
                        key: "open_step",
                        expression: Term(Factor(Literal(Number(2.0)))),
                    )),
                    StoryMessage((
                        speaker: "You",
                        text: "Copy, Okono. She's a big one. What's Mesa Verde want off her?",
                    )),
                ],
            ),
            (
                name: OnUpdate,
                filters: [
                    Expression((Equal(
                        Term(Factor(Name("open_step"))),
                        Term(Factor(Literal(Number(2.0)))),
                    ))),
                    Expression((GreaterThan(
                        Term(Factor(Name("scenario_elapsed"))),
                        Term(Factor(Literal(Number(20.0)))),
                    ))),
                ],
                actions: [
                    VariableSet((
                        key: "open_step",
                        expression: Term(Factor(Literal(Number(3.0)))),
                    )),
                    StoryMessage((
                        speaker: "Foreman Okono",
                        text: "Three containers on the manifest, that's the whole contract. Strip it clean and we call it a shift. Quota's quota.",
                        dwell: Some(7.0),
                    )),
                ],
            ),
            (
                name: OnUpdate,
                filters: [
                    Expression((Equal(
                        Term(Factor(Name("open_step"))),
                        Term(Factor(Literal(Number(3.0)))),
                    ))),
                    Expression((GreaterThan(
                        Term(Factor(Name("scenario_elapsed"))),
                        Term(Factor(Literal(Number(29.0)))),
                    ))),
                ],
                actions: [
                    VariableSet((
                        key: "open_step",
                        expression: Term(Factor(Literal(Number(4.0)))),
                    )),
                    StoryMessage((
                        speaker: "You",
                        text: "Understood. Working the wreck line now.",
                    )),
                ],
            ),
            // The hand-off: the briefing is done, so lazy-post the first
            // crate objective and its marker. Gated quota_posted == 0 so it
            // fires exactly once. The other two crate objectives post on
            // pickup, a beat apart, in the OnEnter handlers below.
            (
                name: OnUpdate,
                filters: [
                    Expression((Equal(
                        Term(Factor(Name("open_step"))),
                        Term(Factor(Literal(Number(4.0)))),
                    ))),
                    Expression((Equal(
                        Term(Factor(Name("quota_posted"))),
                        Term(Factor(Literal(Number(0.0)))),
                    ))),
                ],
                actions: [
                    VariableSet((
                        key: "quota_posted",
                        expression: Term(Factor(Literal(Number(1.0)))),
                    )),
                    ObjectiveComplete((
                        id: "obj_ch1_recap",
                    )),
                    Objective((
                        id: "obj_crate_1",
                        message: "Salvage container MV-1.",
                    )),
                    ObjectiveMarkerAttach((
                        target_id: "ledger_crate_1",
                        label: "MV-1",
                    )),
                    Objective((
                        id: "obj_crate_2",
                        message: "Salvage container MV-2.",
                    )),
                    ObjectiveMarkerAttach((
                        target_id: "ledger_crate_2",
                        label: "MV-2",
                    )),
                    Objective((
                        id: "obj_crate_3",
                        message: "Salvage container MV-3.",
                    )),
                    ObjectiveMarkerAttach((
                        target_id: "ledger_crate_3",
                        label: "MV-3",
                    )),
                ],
            ),
            // --- Act 1: the quota. One handler per crate, order-free. ---
            (
                name: OnEnter,
                filters: [
                    Entity((
                        id: Some("ledger_crate_1"),
                        other_id: Some("player_spaceship"),
                    )),
                    Expression((Equal(
                        Term(Factor(Name("act"))),
                        Term(Factor(Literal(Number(1.0)))),
                    ))),
                ],
                actions: [
                    DespawnScenarioObject((
                        id: "ledger_crate_1",
                    )),
                    VariableSet((
                        key: "crates",
                        expression: Add(Factor(Name("crates")), Term(Factor(Literal(Number(1.0))))),
                    )),
                    ObjectiveComplete((
                        id: "obj_crate_1",
                    )),
                    // Breather: stamp this crate's OWN gate and hand the
                    // follow-up Okono line to the delayed handler below, so
                    // the acknowledgment lands a beat after the pickup, not
                    // on the same frame (the beat-sheet breather). Per-crate
                    // gates keep the three pickups order-free and independent.
                    VariableSet((
                        key: "ack1_gate",
                        expression: Add(Factor(Name("scenario_elapsed")), Term(Factor(Literal(Number(2.5))))),
                    )),
                ],
            ),
            (
                name: OnEnter,
                filters: [
                    Entity((
                        id: Some("ledger_crate_2"),
                        other_id: Some("player_spaceship"),
                    )),
                    Expression((Equal(
                        Term(Factor(Name("act"))),
                        Term(Factor(Literal(Number(1.0)))),
                    ))),
                ],
                actions: [
                    DespawnScenarioObject((
                        id: "ledger_crate_2",
                    )),
                    VariableSet((
                        key: "crates",
                        expression: Add(Factor(Name("crates")), Term(Factor(Literal(Number(1.0))))),
                    )),
                    ObjectiveComplete((
                        id: "obj_crate_2",
                    )),
                    VariableSet((
                        key: "ack2_gate",
                        expression: Add(Factor(Name("scenario_elapsed")), Term(Factor(Literal(Number(2.5))))),
                    )),
                ],
            ),
            (
                name: OnEnter,
                filters: [
                    Entity((
                        id: Some("ledger_crate_3"),
                        other_id: Some("player_spaceship"),
                    )),
                    Expression((Equal(
                        Term(Factor(Name("act"))),
                        Term(Factor(Literal(Number(1.0)))),
                    ))),
                ],
                actions: [
                    DespawnScenarioObject((
                        id: "ledger_crate_3",
                    )),
                    VariableSet((
                        key: "crates",
                        expression: Add(Factor(Name("crates")), Term(Factor(Literal(Number(1.0))))),
                    )),
                    ObjectiveComplete((
                        id: "obj_crate_3",
                    )),
                    VariableSet((
                        key: "ack3_gate",
                        expression: Add(Factor(Name("scenario_elapsed")), Term(Factor(Literal(Number(2.5))))),
                    )),
                ],
            ),
            // The three delayed pickup acknowledgments: each fires a beat
            // after ITS crate is on the hook (clock_past the crate's own
            // stamped gate), one line per handler. The gate is seeded 0 and
            // only stamped by that crate's pickup, and the ackN_said guard
            // makes each a one-shot - so the three are independent and the
            // pickups stay order-free.
            (
                name: OnUpdate,
                filters: [
                    Expression((GreaterThan(
                        Term(Factor(Name("ack1_gate"))),
                        Term(Factor(Literal(Number(0.0)))),
                    ))),
                    Expression((Equal(
                        Term(Factor(Name("ack1_said"))),
                        Term(Factor(Literal(Number(0.0)))),
                    ))),
                    Expression((GreaterThan(
                        Term(Factor(Name("scenario_elapsed"))),
                        Term(Factor(Name("ack1_gate"))),
                    ))),
                ],
                actions: [
                    VariableSet((
                        key: "ack1_said",
                        expression: Term(Factor(Literal(Number(1.0)))),
                    )),
                    StoryMessage((
                        speaker: "Foreman Okono",
                        text: "MV-1 on the hook. Two to go.",
                    )),
                ],
            ),
            (
                name: OnUpdate,
                filters: [
                    Expression((GreaterThan(
                        Term(Factor(Name("ack2_gate"))),
                        Term(Factor(Literal(Number(0.0)))),
                    ))),
                    Expression((Equal(
                        Term(Factor(Name("ack2_said"))),
                        Term(Factor(Literal(Number(0.0)))),
                    ))),
                    Expression((GreaterThan(
                        Term(Factor(Name("scenario_elapsed"))),
                        Term(Factor(Name("ack2_gate"))),
                    ))),
                ],
                actions: [
                    VariableSet((
                        key: "ack2_said",
                        expression: Term(Factor(Literal(Number(1.0)))),
                    )),
                    StoryMessage((
                        speaker: "Foreman Okono",
                        text: "MV-2 logged. Keep it moving, the Matron isn't getting any deader.",
                    )),
                ],
            ),
            (
                name: OnUpdate,
                filters: [
                    Expression((GreaterThan(
                        Term(Factor(Name("ack3_gate"))),
                        Term(Factor(Literal(Number(0.0)))),
                    ))),
                    Expression((Equal(
                        Term(Factor(Name("ack3_said"))),
                        Term(Factor(Literal(Number(0.0)))),
                    ))),
                    Expression((GreaterThan(
                        Term(Factor(Name("scenario_elapsed"))),
                        Term(Factor(Name("ack3_gate"))),
                    ))),
                ],
                actions: [
                    VariableSet((
                        key: "ack3_said",
                        expression: Term(Factor(Literal(Number(1.0)))),
                    )),
                    StoryMessage((
                        speaker: "Foreman Okono",
                        text: "MV-3. That's the manifest done.",
                    )),
                ],
            ),
            // Quota met (`> 2`, not `== 3`: a double-fire cannot skip the
            // gate - the count-gate lesson) -> act 2. This only ARMS the
            // reveal (stamps ping_gate); the reveal itself is the chapter's
            // hook, so it gets its own announce -> breathe -> objective beats
            // below, not a single frame-0 dump.
            (
                name: OnUpdate,
                filters: [
                    Expression((Equal(
                        Term(Factor(Name("act"))),
                        Term(Factor(Literal(Number(1.0)))),
                    ))),
                    Expression((GreaterThan(
                        Term(Factor(Name("crates"))),
                        Term(Factor(Literal(Number(2.0)))),
                    ))),
                ],
                actions: [
                    VariableSet((
                        key: "act",
                        expression: Term(Factor(Literal(Number(2.0)))),
                    )),
                    // Let the "manifest done" line breathe before the hook.
                    VariableSet((
                        key: "ping_gate",
                        expression: Add(Factor(Name("scenario_elapsed")), Term(Factor(Literal(Number(4.0))))),
                    )),
                ],
            ),
            // The 4th-ping reveal ANNOUNCE (a beat after the quota closes):
            // one line, then re-stamp the gate for the objective breather.
            (
                name: OnUpdate,
                filters: [
                    Expression((Equal(
                        Term(Factor(Name("act"))),
                        Term(Factor(Literal(Number(2.0)))),
                    ))),
                    Expression((Equal(
                        Term(Factor(Name("ping_said"))),
                        Term(Factor(Literal(Number(0.0)))),
                    ))),
                    Expression((GreaterThan(
                        Term(Factor(Name("scenario_elapsed"))),
                        Term(Factor(Name("ping_gate"))),
                    ))),
                ],
                actions: [
                    VariableSet((
                        key: "ping_said",
                        expression: Term(Factor(Literal(Number(1.0)))),
                    )),
                    VariableSet((
                        key: "beat_gate",
                        expression: Add(Factor(Name("scenario_elapsed")), Term(Factor(Literal(Number(3.5))))),
                    )),
                    StoryMessage((
                        speaker: "Foreman Okono",
                        text: "Hold up. Scope's showing a fourth return, deep in the stern... that container is not on any manifest I've ever filed.",
                        dwell: Some(8.0),
                    )),
                    // The belt turns wrong the moment the black box shows up.
                    // Fires once (ping_said 0 -> 1 guard above).
                    SetSkybox((cubemap: "dep://base/textures/cubemap_alt.png")),
                ],
            ),
            // The reveal BREATHE -> objective: the unlogged container posts a
            // beat after the reveal line lands (ping_said == 1, clock past
            // the re-stamped beat_gate), guarded by setup_last so it fires
            // once.
            (
                name: OnUpdate,
                filters: [
                    Expression((Equal(
                        Term(Factor(Name("ping_said"))),
                        Term(Factor(Literal(Number(1.0)))),
                    ))),
                    Expression((LessThan(
                        Term(Factor(Name("setup_last"))),
                        Term(Factor(Literal(Number(1.0)))),
                    ))),
                    Expression((GreaterThan(
                        Term(Factor(Name("scenario_elapsed"))),
                        Term(Factor(Name("beat_gate"))),
                    ))),
                ],
                actions: [
                    VariableSet((
                        key: "setup_last",
                        expression: Term(Factor(Literal(Number(1.0)))),
                    )),
                    Objective((
                        id: "obj_blackbox",
                        message: "Investigate the unlogged container.",
                    )),
                    ObjectiveMarkerAttach((
                        target_id: "ledger_blackbox",
                        label: "UNLOGGED",
                    )),
                ],
            ),
            // The black box -> act 3, victory, chapter 2.
            (
                name: OnEnter,
                filters: [
                    Entity((
                        id: Some("ledger_blackbox"),
                        other_id: Some("player_spaceship"),
                    )),
                    Expression((Equal(
                        Term(Factor(Name("act"))),
                        Term(Factor(Literal(Number(2.0)))),
                    ))),
                ],
                actions: [
                    DespawnScenarioObject((
                        id: "ledger_blackbox",
                    )),
                    VariableSet((
                        key: "act",
                        expression: Term(Factor(Literal(Number(3.0)))),
                    )),
                    ObjectiveComplete((
                        id: "obj_blackbox",
                    )),
                    Outcome((
                        outcome: Victory,
                        message: Some("The quota's in the hold - and so is a sealed military casing that was never on the books. Okono's board is already lighting up with buyers nobody called."),
                    )),
                    NextScenario((
                        scenario_id: "ledger_ch2_claim_jumpers",
                        linger: true,
                    )),
                ],
            ),
            // Player death before the win: Defeat + retry this chapter.
            // Gated act < 3 so a post-victory death cannot overwrite the win.
            (
                name: OnDestroyed,
                filters: [
                    Entity((
                        id: Some("player_spaceship"),
                    )),
                    Expression((LessThan(
                        Term(Factor(Name("act"))),
                        Term(Factor(Literal(Number(3.0)))),
                    ))),
                ],
                actions: [
                    Outcome((
                        outcome: Defeat,
                        message: Some("The belt keeps the Kestrel. Mesa Verde files the claim, and the debt rolls over."),
                    )),
                    NextScenario((
                        scenario_id: "ledger_ch1_dead_weight",
                        linger: true,
                    )),
                ],
            ),
        ],
    )),
]
