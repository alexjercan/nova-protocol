                            ],
                        )),
                    )),
                    // The nav line: three drops and the yard, each a trigger
                    // beacon (the gauntlet gate bundle).
                    SpawnScenarioObject((
                        base: (
                            id: "nav_1",
                            name: "Nav Drop 1",
                            position: (0.0, 0.0, -90.0),
                            rotation: (0.0, 0.0, 0.0, 1.0),
                        ),
                        kind: Beacon((
                            label: "NAV-1",
                            radius: 2.0,
                            color: Srgba((red: 0.3, green: 0.9, blue: 1.0, alpha: 1.0)),
                            area_radius: Some(25.0),
                            lock_signature: None,
                        )),
                    )),
                    SpawnScenarioObject((
                        base: (
                            id: "nav_2",
                            name: "Nav Drop 2",
                            position: (60.0, 15.0, -180.0),
                            rotation: (0.0, 0.0, 0.0, 1.0),
                        ),
                        kind: Beacon((
                            label: "NAV-2",
                            radius: 2.0,
                            color: Srgba((red: 0.3, green: 0.9, blue: 1.0, alpha: 1.0)),
                            area_radius: Some(25.0),
                            lock_signature: None,
                        )),
                    )),
                    SpawnScenarioObject((
                        base: (
                            id: "nav_3",
                            name: "Nav Drop 3",
                            position: (-40.0, -20.0, -280.0),
                            rotation: (0.0, 0.0, 0.0, 1.0),
                        ),
                        kind: Beacon((
                            label: "NAV-3",
                            radius: 2.0,
                            color: Srgba((red: 0.3, green: 0.9, blue: 1.0, alpha: 1.0)),
                            area_radius: Some(25.0),
                            lock_signature: None,
                        )),
                    )),
                    SpawnScenarioObject((
                        base: (
                            id: "vesh_yard",
                            name: "Vesh's Yard",
                            position: (20.0, 0.0, -380.0),
                            rotation: (0.0, 0.0, 0.0, 1.0),
                        ),
                        kind: Beacon((
                            label: "YARD",
                            radius: 3.0,
                            color: Srgba((red: 1.0, green: 0.55, blue: 0.15, alpha: 1.0)),
                            area_radius: Some(30.0),
                            lock_signature: None,
                        )),
                    )),
                    // The DEBRIS PINCH (task 20260722-214105): the chapter's
                    // second, distinct encounter - a PILOTING hazard, not a
                    // fight. Two invulnerable boulders straddle the NAV-1 ->
                    // NAV-2 leg so the lane threads between them. Nominal radii
                    // are small on purpose: asteroid bodies run 3.5x-6x nominal
                    // (ASTEROID_GEOMETRIC_FACTOR_MIN/MAX), so a nominal 3.5 is a
                    // ~12-21u boulder. Centres are placed on a perpendicular to
                    // the leg through its midpoint (30, 7.5, -135), separated
                    // 66u, leaving a clear gap (~66 - 2*21 = 24u at the 6x
                    // worst case) far wider than the tug (~4u body) - a careful
                    // pilot threads it, preserving the fighting-is-optional
                    // contract. No lock will save the player here; it is flown.
                    SpawnScenarioObject((
                        base: (
                            id: "pinch_boulder_port",
                            name: "Channel Boulder",
                            position: (2.5, 7.5, -153.3),
                            rotation: (0.0, 0.0, 0.0, 1.0),
                        ),
                        kind: Asteroid((
                            radius: 3.5,
                            texture: "dep://base/textures/asteroid.png",
                            health: 1000.0,
                            surface_gravity: None,
                            invulnerable: true,
                            lock_signature: None,
                        )),
                    )),
                    SpawnScenarioObject((
                        base: (
                            id: "pinch_boulder_starboard",
                            name: "Channel Boulder",
                            position: (57.5, 7.5, -116.7),
                            rotation: (0.0, 0.0, 0.0, 1.0),
                        ),
                        kind: Asteroid((
                            radius: 3.5,
                            texture: "dep://base/textures/asteroid.png",
                            health: 1000.0,
                            surface_gravity: None,
                            invulnerable: true,
                            lock_signature: None,
                        )),
                    )),
                    // A silent trigger beacon on the far side of the pinch, on
                    // the leg past the gap, so the "you're through" confirm
                    // line fires when the player clears it (not on a timer).
                    SpawnScenarioObject((
                        base: (
                            id: "pinch_clear",
                            name: "Channel Narrows",
                            position: (45.0, 11.0, -160.0),
                            rotation: (0.0, 0.0, 0.0, 1.0),
                        ),
                        kind: Beacon((
                            label: "NARROWS",
                            radius: 1.0,
                            color: Srgba((red: 0.9, green: 0.6, blue: 0.2, alpha: 1.0)),
                            area_radius: Some(22.0),
                            lock_signature: None,
                        )),
                    )),
                    // The channel: dense breakable debris around the line.
                    ScatterObjects((
                        id_prefix: "channel_debris_",
                        count: 26,
                        seed: 4473,
                        region: Ring(
                            inner: 60.0,
                            outer: 200.0,
                            y_min: -60.0,
                            y_max: 40.0,
                        ),
                        template: (
                            base: (
                                id: "channel_debris_",
                                name: "Channel Debris",
                                position: (0.0, 0.0, 0.0),
                                rotation: (0.0, 0.0, 0.0, 1.0),
                            ),
                            kind: Asteroid((
                impact_sound: Some("dep://base/sounds/impact.wav"),
                destroy_sound: Some("dep://base/sounds/explosion.wav"),
                                radius: 1.0,
                                texture: "dep://base/textures/asteroid.png",
                                health: 100.0,
                                surface_gravity: None,
                                invulnerable: false,
                                lock_signature: None,
                            )),
                        ),
                        asteroid_radius: Some((1.5, 4.0)),
                    )),
                ],
            ),
            // --- Opening conversation (the Shakedown/ch1 idiom): Vesh briefs
            // over the scenario clock, one line per handler/beat, spaced ~9s
            // apart, the player answering. The objectives panel holds on the
            // stand-by line the whole time; the first NAV objective lazy-posts
            // only when the briefing hands off (open_step == 4 below), so a
            // blind burn cannot start threading before the run is called. ---
            (
                name: OnUpdate,
                filters: [
                    Expression((Equal(
                        Term(Factor(Name("open_step"))),
                        Term(Factor(Literal(Number(0.0)))),
                    ))),
                    Expression((GreaterThan(
                        Term(Factor(Name("scenario_elapsed"))),
                        Term(Factor(Literal(Number(2.0)))),
                    ))),
                ],
                actions: [
                    VariableSet((
                        key: "open_step",
                        expression: Term(Factor(Literal(Number(1.0)))),
                    )),
                    StoryMessage((
                        speaker: "Broker Vesh",
                        text: "New voice on the channel. Vesh. I run this stretch of belt - and right now I run the only clean way to my yard.",
                        dwell: Some(7.0),
                    )),
                ],
            ),
            (
                name: OnUpdate,
                filters: [
                    Expression((Equal(
                        Term(Factor(Name("open_step"))),
                        Term(Factor(Literal(Number(1.0)))),
                    ))),
                    Expression((GreaterThan(
                        Term(Factor(Name("scenario_elapsed"))),
                        Term(Factor(Literal(Number(11.0)))),
                    ))),
                ],
                actions: [
                    VariableSet((
                        key: "open_step",
                        expression: Term(Factor(Literal(Number(2.0)))),
                    )),
                    StoryMessage((
                        speaker: "You",
                        text: "Copy, Vesh. I\'ve got a box that half the belt wants. What\'s the way in?",
                    )),
                ],
            ),
            (
                name: OnUpdate,
                filters: [
                    Expression((Equal(
                        Term(Factor(Name("open_step"))),
                        Term(Factor(Literal(Number(2.0)))),
                    ))),
                    Expression((GreaterThan(
                        Term(Factor(Name("scenario_elapsed"))),
                        Term(Factor(Literal(Number(20.0)))),
                    ))),
                ],
                actions: [
                    VariableSet((
                        key: "open_step",
                        expression: Term(Factor(Literal(Number(3.0)))),
                    )),
                    StoryMessage((
                        speaker: "Broker Vesh",
                        text: "Run dark through the channel to my yard. I\'ll drop nav beacons - follow them in order, stay off the rocks, and stray off the line and the channel does the Magpies\' work for them.",
                        dwell: Some(9.0),
                    )),
                ],
            ),
            (
                name: OnUpdate,
                filters: [
                    Expression((Equal(
                        Term(Factor(Name("open_step"))),
                        Term(Factor(Literal(Number(3.0)))),
                    ))),
                    Expression((GreaterThan(
                        Term(Factor(Name("scenario_elapsed"))),
                        Term(Factor(Literal(Number(30.0)))),
                    ))),
                ],
                actions: [
                    VariableSet((
                        key: "open_step",
                        expression: Term(Factor(Literal(Number(4.0)))),
                    )),
                    StoryMessage((
                        speaker: "You",
                        text: "Going dark. Bring up your first drop.",
                    )),
                ],
            ),
            // The hand-off: the briefing is done, so lazy-post the NAV
            // objective and complete the holding recap. Gated nav_posted == 0
            // so it fires exactly once (the count-gate lesson).
            (
                name: OnUpdate,
                filters: [
                    Expression((Equal(
                        Term(Factor(Name("open_step"))),
                        Term(Factor(Literal(Number(4.0)))),
                    ))),
                    Expression((Equal(
                        Term(Factor(Name("nav_posted"))),
                        Term(Factor(Literal(Number(0.0)))),
                    ))),
                ],
                actions: [
                    VariableSet((
                        key: "nav_posted",
                        expression: Term(Factor(Literal(Number(1.0)))),
                    )),
                    ObjectiveComplete((
                        id: "obj_ch3_recap",
                    )),
                    Objective((
                        id: "obj_gates",
                        message: "Thread the NAV drops in order: 1, 2, 3, then the YARD.",
                    )),
                ],
            ),
            // --- The gate line (strictly sequential: gate == N guards). ---
            // NAV-1 advances the line AND arms the debris-pinch beat: it stamps
            // pinch_gate so Vesh's "channel narrows" warning lands a beat later
            // (announce -> arrive -> confirm -> breathe), not in the same frame
            // as the arrival line.
            (
                name: OnEnter,
                filters: [
                    Entity((
                        id: Some("nav_1"),
                        other_id: Some("player_spaceship"),
                    )),
                    Expression((Equal(
                        Term(Factor(Name("gate"))),
                        Term(Factor(Literal(Number(1.0)))),
                    ))),
                ],
                actions: [
                    VariableSet((
                        key: "gate",
                        expression: Term(Factor(Literal(Number(2.0)))),
                    )),
                    // Arm the pinch-warning breather (fires ~4s after this
                    // arrival line, before the player reaches the boulders).
                    VariableSet((
                        key: "pinch_gate",
                        expression: Add(Factor(Name("scenario_elapsed")), Term(Factor(Literal(Number(4.0))))),
                    )),
                    StoryMessage((
                        speaker: "Broker Vesh",
                        text: "Drop one. Keep your burn low, the channel listens.",
                    )),
                ],
            ),
            // The pinch WARNING (a beat after the NAV-1 line): thread it slow.
            // One-shot on pinch_warn_said, gated on the clock past pinch_gate.
            (
                name: OnUpdate,
                filters: [
                    Expression((Equal(
                        Term(Factor(Name("pinch_warn_said"))),
                        Term(Factor(Literal(Number(0.0)))),
                    ))),
                    Expression((GreaterThan(
                        Term(Factor(Name("pinch_gate"))),
                        Term(Factor(Literal(Number(0.0)))),
                    ))),
                    Expression((GreaterThan(
                        Term(Factor(Name("scenario_elapsed"))),
                        Term(Factor(Name("pinch_gate"))),
                    ))),
                ],
                actions: [
                    VariableSet((
                        key: "pinch_warn_said",
                        expression: Term(Factor(Literal(Number(1.0)))),
                    )),
                    StoryMessage((
                        speaker: "Broker Vesh",
                        text: "Channel narrows here - two old wrecks the size of houses, and the gap between them is barely a lane. Thread it slow. No lock will save you off the rocks.",
                        dwell: Some(9.0),
                    )),
                    // The channel closes in: darker sky for the pinch. Fires
                    // once (pinch_warn_said 0 -> 1 guard above).
                    SetSkybox((cubemap: "dep://base/textures/cubemap_alt.png")),
                ],
            ),
            // The pinch CONFIRM: fires when the player clears the NARROWS
            // trigger on the far side of the gap. One-shot on pinch_clear_said;
            // gated pinch_warn_said == 1 so it cannot pre-empt the warning.
            (
                name: OnEnter,
                filters: [
                    Entity((
                        id: Some("pinch_clear"),
                        other_id: Some("player_spaceship"),
                    )),
                    Expression((Equal(
                        Term(Factor(Name("pinch_clear_said"))),
                        Term(Factor(Literal(Number(0.0)))),
                    ))),
                    Expression((Equal(
                        Term(Factor(Name("pinch_warn_said"))),
                        Term(Factor(Literal(Number(1.0)))),
                    ))),
                ],
                actions: [
                    VariableSet((
                        key: "pinch_clear_said",
                        expression: Term(Factor(Literal(Number(1.0)))),
                    )),
                    StoryMessage((
                        speaker: "Broker Vesh",
                        text: "Clean through. Steady hands, Kestrel. The line opens up ahead - close on drop two.",
                        dwell: Some(6.0),
                    )),
                ],
            ),
            // NAV-2 advances the line AND springs the ambush - the channel
            // was never empty.
            (
                name: OnEnter,
