// The Ledger, chapter 3 of 4: THE QUIET CHANNEL. Run the box to Broker
// Vesh's yard through the debris channel - thread the NAV gates in order
// (the gauntlet's expression-guarded sequencing) with one mid-channel
// Magpie ambush (act-gated spawn on the NAV-2 trigger). Fighting the ambush
// is optional; the gates are the objective.
//
// `gate` is the sequencing variable (1..4); `act` 1 = running, 2 = arrived.
// Player-death Defeat gates act < 2.
[
    Scenario((
        id: "ledger_ch3_quiet_channel",
        name: "The Ledger 3: The Quiet Channel",
        description: "Go dark and thread the debris channel to Vesh's yard. Chapter three of The Ledger.",
        cubemap: "textures/cubemap_alt2.png",
        thumbnail: Some("textures/asteroid.png"),
        hidden: true,
        events: [
            (
                name: OnStart,
                filters: [],
                actions: [
                    VariableSet((
                        key: "act",
                        expression: Term(Factor(Literal(Number(1.0)))),
                    )),
                    VariableSet((
                        key: "gate",
                        expression: Term(Factor(Literal(Number(1.0)))),
                    )),
                    StoryMessage((
                        speaker: "Broker Vesh",
                        text: "New voice on the channel. Vesh. Follow my nav drops through the debris - stray off the line and the channel will do the Magpies' work for them.",
                    )),
                    Objective((
                        id: "obj_ch3_recap",
                        message: "Ch.3 - The Quiet Channel: deliver the box to Vesh's yard.",
                    )),
                    Objective((
                        id: "obj_gates",
                        message: "Thread the NAV drops in order: 1, 2, 3, then the YARD.",
                    )),
                    SpawnScenarioObject((
                        base: (
                            id: "player_spaceship",
                            name: "Salvage Tug Kestrel",
                            position: (0.0, 0.0, 40.0),
                            rotation: (0.0, 0.0, 0.0, 1.0),
                        ),
                        kind: Spaceship((
                            controller: Player((
                                input_mapping: {
                                    "turret": [
                                        Mouse(Left),
                                        Gamepad(RightTrigger2),
                                    ],
                                },
                                speed_cap: Some(25.0),
                                infinite_ammo: true,
                            )),
                            sections: [
                                (
                                    id: "controller",
                                    position: (0.0, 0.0, 0.0),
                                    rotation: (0.0, 0.0, 0.0, 1.0),
                                    source: Prototype("basic_controller_section"),
                                ),
                                (
                                    id: "hull_front",
                                    position: (0.0, 0.0, 1.0),
                                    rotation: (0.0, 0.0, 0.0, 1.0),
                                    source: Prototype("reinforced_hull_section"),
                                ),
                                (
                                    id: "thruster",
                                    position: (0.0, 0.0, 2.0),
                                    rotation: (0.0, 0.0, 0.0, 1.0),
                                    source: Prototype("basic_thruster_section"),
                                ),
                                (
                                    id: "turret",
                                    position: (0.0, 0.0, -1.0),
                                    rotation: (-0.70710677, 0.0, 0.0, 0.70710677),
                                    source: Prototype("better_turret_section"),
                                ),
                            ],
                        )),
                    )),
                    // The nav line: three drops and the yard, each a trigger
                    // beacon (the gauntlet gate bundle).
                    SpawnScenarioObject((
                        base: (
                            id: "nav_1",
                            name: "Nav Drop 1",
                            position: (0.0, 0.0, -90.0),
                            rotation: (0.0, 0.0, 0.0, 1.0),
                        ),
                        kind: Beacon((
                            label: "NAV-1",
                            radius: 2.0,
                            color: Srgba((red: 0.3, green: 0.9, blue: 1.0, alpha: 1.0)),
                            area_radius: Some(25.0),
                            lock_signature: None,
                        )),
                    )),
                    SpawnScenarioObject((
                        base: (
                            id: "nav_2",
                            name: "Nav Drop 2",
                            position: (60.0, 15.0, -180.0),
                            rotation: (0.0, 0.0, 0.0, 1.0),
                        ),
                        kind: Beacon((
                            label: "NAV-2",
                            radius: 2.0,
                            color: Srgba((red: 0.3, green: 0.9, blue: 1.0, alpha: 1.0)),
                            area_radius: Some(25.0),
                            lock_signature: None,
                        )),
                    )),
                    SpawnScenarioObject((
                        base: (
                            id: "nav_3",
                            name: "Nav Drop 3",
                            position: (-40.0, -20.0, -280.0),
                            rotation: (0.0, 0.0, 0.0, 1.0),
                        ),
                        kind: Beacon((
                            label: "NAV-3",
                            radius: 2.0,
                            color: Srgba((red: 0.3, green: 0.9, blue: 1.0, alpha: 1.0)),
                            area_radius: Some(25.0),
                            lock_signature: None,
                        )),
                    )),
                    SpawnScenarioObject((
                        base: (
                            id: "vesh_yard",
                            name: "Vesh's Yard",
                            position: (20.0, 0.0, -380.0),
                            rotation: (0.0, 0.0, 0.0, 1.0),
                        ),
                        kind: Beacon((
                            label: "YARD",
                            radius: 3.0,
                            color: Srgba((red: 1.0, green: 0.55, blue: 0.15, alpha: 1.0)),
                            area_radius: Some(30.0),
                            lock_signature: None,
                        )),
                    )),
                    // The channel: dense breakable debris around the line.
                    ScatterObjects((
                        id_prefix: "channel_debris_",
                        count: 26,
                        seed: 4473,
                        region: Ring(
                            inner: 60.0,
                            outer: 200.0,
                            y_min: -60.0,
                            y_max: 40.0,
                        ),
                        template: (
                            base: (
                                id: "channel_debris_",
                                name: "Channel Debris",
                                position: (0.0, 0.0, 0.0),
                                rotation: (0.0, 0.0, 0.0, 1.0),
                            ),
                            kind: Asteroid((
                                radius: 1.0,
                                texture: "textures/asteroid.png",
                                health: 100.0,
                                surface_gravity: None,
                                invulnerable: false,
                                lock_signature: None,
                            )),
                        ),
                        asteroid_radius: Some((1.5, 4.0)),
                    )),
                ],
            ),
            // --- The gate line (strictly sequential: gate == N guards). ---
            (
                name: OnEnter,
                filters: [
                    Entity((
                        id: Some("nav_1"),
                        other_id: Some("player_spaceship"),
                    )),
                    Expression((Equal(
                        Term(Factor(Name("gate"))),
                        Term(Factor(Literal(Number(1.0)))),
                    ))),
                ],
                actions: [
                    VariableSet((
                        key: "gate",
                        expression: Term(Factor(Literal(Number(2.0)))),
                    )),
                    StoryMessage((
                        speaker: "Broker Vesh",
                        text: "Drop one. Keep your burn low, the channel listens.",
                    )),
                ],
            ),
            // NAV-2 advances the line AND springs the ambush - the channel
            // was never empty.
            (
                name: OnEnter,
                filters: [
                    Entity((
                        id: Some("nav_2"),
                        other_id: Some("player_spaceship"),
                    )),
                    Expression((Equal(
                        Term(Factor(Name("gate"))),
                        Term(Factor(Literal(Number(2.0)))),
                    ))),
                ],
                actions: [
                    VariableSet((
                        key: "gate",
                        expression: Term(Factor(Literal(Number(3.0)))),
                    )),
                    StoryMessage((
                        speaker: "Broker Vesh",
                        text: "Contacts. Magpies laid up dark in the field. Run or fight, but the line is still the line, Kestrel.",
                    )),
                    SpawnScenarioObject((
                        base: (
                            id: "channel_magpie_1",
                            name: "Magpie 'Loose Tooth'",
                            position: (120.0, 20.0, -220.0),
                            rotation: (0.0, 0.0, 0.0, 1.0),
                        ),
                        kind: Spaceship((
                            controller: AI(()),
                            sections: [
                                (
                                    id: "controller",
                                    position: (0.0, 0.0, 0.0),
                                    rotation: (0.0, 0.0, 0.0, 1.0),
                                    source: Prototype("basic_controller_section"),
                                ),
                                (
                                    id: "hull_front",
                                    position: (0.0, 0.0, 1.0),
                                    rotation: (0.0, 0.0, 0.0, 1.0),
                                    source: Prototype("light_hull_section"),
                                ),
                                (
                                    id: "thruster",
                                    position: (0.0, 0.0, 2.0),
                                    rotation: (0.0, 0.0, 0.0, 1.0),
                                    source: Prototype("basic_thruster_section"),
                                ),
                                (
                                    id: "turret",
                                    position: (0.0, 0.0, -1.0),
                                    rotation: (-0.70710677, 0.0, 0.0, 0.70710677),
                                    source: Prototype("light_turret_section"),
                                ),
                            ],
                        )),
                    )),
                    SpawnScenarioObject((
                        base: (
                            id: "channel_magpie_2",
                            name: "Magpie 'Second Owner'",
                            position: (-90.0, -30.0, -240.0),
                            rotation: (0.0, 0.0, 0.0, 1.0),
                        ),
                        kind: Spaceship((
                            controller: AI(()),
                            sections: [
                                (
                                    id: "controller",
                                    position: (0.0, 0.0, 0.0),
                                    rotation: (0.0, 0.0, 0.0, 1.0),
                                    source: Prototype("basic_controller_section"),
                                ),
                                (
                                    id: "hull_front",
                                    position: (0.0, 0.0, 1.0),
                                    rotation: (0.0, 0.0, 0.0, 1.0),
                                    source: Prototype("light_hull_section"),
                                ),
                                (
                                    id: "thruster",
                                    position: (0.0, 0.0, 2.0),
                                    rotation: (0.0, 0.0, 0.0, 1.0),
                                    source: Prototype("basic_thruster_section"),
                                ),
                                (
                                    id: "turret",
                                    position: (0.0, 0.0, -1.0),
                                    rotation: (-0.70710677, 0.0, 0.0, 0.70710677),
                                    source: Prototype("light_turret_section"),
                                ),
                            ],
                        )),
                    )),
                ],
            ),
            (
                name: OnEnter,
                filters: [
                    Entity((
                        id: Some("nav_3"),
                        other_id: Some("player_spaceship"),
                    )),
                    Expression((Equal(
                        Term(Factor(Name("gate"))),
                        Term(Factor(Literal(Number(3.0)))),
                    ))),
                ],
                actions: [
                    VariableSet((
                        key: "gate",
                        expression: Term(Factor(Literal(Number(4.0)))),
                    )),
                    StoryMessage((
                        speaker: "Broker Vesh",
                        text: "Drop three. The yard lights are on for you. Last leg.",
                    )),
                ],
            ),
            // The yard: chapter won.
            (
                name: OnEnter,
                filters: [
                    Entity((
                        id: Some("vesh_yard"),
                        other_id: Some("player_spaceship"),
                    )),
                    Expression((Equal(
                        Term(Factor(Name("gate"))),
                        Term(Factor(Literal(Number(4.0)))),
                    ))),
                ],
                actions: [
                    VariableSet((
                        key: "act",
                        expression: Term(Factor(Literal(Number(2.0)))),
                    )),
                    ObjectiveComplete((
                        id: "obj_gates",
                    )),
                    StoryMessage((
                        speaker: "Broker Vesh",
                        text: "Welcome to the yard, Kestrel. Now let's talk about who exactly is buying this thing.",
                    )),
                    Outcome((
                        outcome: Victory,
                        message: Some("The channel is behind you. The buyer is ahead."),
                    )),
                    NextScenario((
                        scenario_id: "ledger_ch4_the_buyer",
                        linger: true,
                    )),
                ],
            ),
            // Player death before arrival: Defeat + retry.
            (
                name: OnDestroyed,
                filters: [
                    Entity((
                        id: Some("player_spaceship"),
                    )),
                    Expression((LessThan(
                        Term(Factor(Name("act"))),
                        Term(Factor(Literal(Number(2.0)))),
                    ))),
                ],
                actions: [
                    Outcome((
                        outcome: Defeat,
                        message: Some("The channel keeps what it catches. The box drifts with the Kestrel's bones."),
                    )),
                    NextScenario((
                        scenario_id: "ledger_ch3_quiet_channel",
                        linger: true,
                    )),
                ],
            ),
        ],
    )),
]
