// The Ledger, chapter 3 of 4: THE QUIET CHANNEL. Run the box to Broker
// Vesh's yard through the debris channel - thread the NAV gates in order
// (the gauntlet's expression-guarded sequencing) with TWO distinct textured
// beats: a mid-channel Magpie ambush (act-gated spawn on the NAV-2 trigger,
// a FIGHT), and a debris pinch between NAV-1 and NAV-2 (two invulnerable
// boulders tightening the lane, a PILOTING hazard). Both are optional to a
// careful pilot; the gates are the objective.
//
// Pacing (task 20260722-214105, the ch1/Shakedown idiom): a clock-paced
// opening conversation (open_step cascade) briefs the run before the first
// NAV objective lazy-posts (nav_posted hand-off); each gate transition stamps
// beat_gate so the next Vesh line lands a beat LATER (announce -> arrive ->
// confirm -> breathe), not in the arrival frame; the pinch has its own
// warning + far-side confirm beats.
//
// `gate` is the sequencing variable (1..4); `act` 1 = running, 2 = arrived.
// Player-death Defeat gates act < 2.
[
    Scenario((
        id: "ledger_ch3_quiet_channel",
        name: "The Ledger 3: The Quiet Channel",
        description: "Go dark and thread the debris channel to Vesh's yard. Chapter three of The Ledger.",
        cubemap: "dep://base/textures/cubemap.png",
        thumbnail: Some("dep://base/textures/asteroid.png"),
        hidden: true,
        events: [
            (
                name: OnStart,
                filters: [],
                actions: [
                    VariableSet((
                        key: "act",
                        expression: Term(Factor(Literal(Number(1.0)))),
                    )),
                    VariableSet((
                        key: "gate",
                        expression: Term(Factor(Literal(Number(1.0)))),
                    )),
                    // Opening-conversation sequencer (the Shakedown/ch1 idiom):
                    // open_step walks Vesh's briefing lines on the scenario
                    // clock; nav_posted is the one-shot hand-off that lazy-
                    // posts the first NAV objective; beat_gate + the per-beat
                    // arrive/said one-shots drive the corridor breathers. All
                    // seeded here - an undefined gate fails closed forever.
                    VariableSet((
                        key: "open_step",
                        expression: Term(Factor(Literal(Number(0.0)))),
                    )),
                    VariableSet((
                        key: "nav_posted",
                        expression: Term(Factor(Literal(Number(0.0)))),
                    )),
                    VariableSet((
                        key: "beat_gate",
                        expression: Term(Factor(Literal(Number(0.0)))),
                    )),
                    // Per-transition breather gates + one-shot said flags. The
                    // delayed ack handlers gate on the *_said flag AND the clock
                    // past beat_gate, so an un-stamped leg never speaks.
                    VariableSet((
                        key: "arrive1_said",
                        expression: Term(Factor(Literal(Number(0.0)))),
                    )),
                    VariableSet((
                        key: "arrive3_said",
                        expression: Term(Factor(Literal(Number(0.0)))),
                    )),
                    // The debris-pinch beat: pinch_gate stamps the breather
                    // after NAV-1, pinch_warn_said is the "thread it slow"
                    // warning one-shot, pinch_clear_said the far-side confirm.
                    VariableSet((
                        key: "pinch_gate",
                        expression: Term(Factor(Literal(Number(0.0)))),
                    )),
                    VariableSet((
                        key: "pinch_warn_said",
                        expression: Term(Factor(Literal(Number(0.0)))),
                    )),
                    VariableSet((
                        key: "pinch_clear_said",
                        expression: Term(Factor(Literal(Number(0.0)))),
                    )),
                    // The objectives panel stays EMPTY through the opening
                    // conversation; this HOLDING line is all that shows until
                    // the briefing hands off to the first NAV drop (beat sheet:
                    // no objective shares a frame with a conversation).
                    Objective((
                        id: "obj_ch3_recap",
                        message: "Ch.3 - The Quiet Channel: stand by for Vesh's nav drops.",
                    )),
                    SpawnScenarioObject((
                        base: (
                            id: "player_spaceship",
                            name: "Salvage Tug Kestrel",
                            position: (0.0, 0.0, 40.0),
                            rotation: (0.0, 0.0, 0.0, 1.0),
                        ),
                        kind: Spaceship((
                            controller: Player((
                                input_mapping: {
                                    "cube_i1_j0_km1": [
