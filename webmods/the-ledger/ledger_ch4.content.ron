                ],
            ),
            // --- The BURN branch (act 1 -> 3, TERMINAL, no fight): torch the
            // box and there is nothing left to collect, so the Auditor never
            // comes. `act` jumps straight to 3 (the "done" latch) SYNCHRONOUS
            // with the choice, so no death window ever opens on this path - the
            // player-death Defeat handler (act < 3) can never fire here. The
            // terminal Victory lands a beat later on `burn_gate` (the burn line
            // plays first, then the overlay), so no StoryMessage sits beside an
            // Outcome. NO auditor spawn - this is the SAFE-BUT-BROKE escape as
            // shipped (owner playtest question 1: bittersweet vs clean tone). ---
            (
                name: OnEnter,
                filters: [
                    Entity((
                        id: Some("burn_buoy"),
                        other_id: Some("player_spaceship"),
                    )),
                    Expression((Equal(
                        Term(Factor(Name("act"))),
                        Term(Factor(Literal(Number(1.0)))),
                    ))),
                ],
                actions: [
                    VariableSet((
                        key: "choice",
                        expression: Term(Factor(Literal(Number(2.0)))),
                    )),
                    // Terminal latch: straight to act 3. Synchronous with the
                    // choice so no death race opens (mirrors how ch2's win
                    // handler bumps act immediately, then defers only overlay).
                    VariableSet((
                        key: "act",
                        expression: Term(Factor(Literal(Number(3.0)))),
                    )),
                    // Stamp the breather deadline; the Victory overlay follows
                    // a beat later via the `burn_said` one-shot handler below.
                    VariableSet((
                        key: "burn_gate",
                        expression: Add(Factor(Name("scenario_elapsed")), Term(Factor(Literal(Number(3.0))))),
                    )),
                    ObjectiveComplete((
                        id: "obj_ch4_recap",
                    )),
                    StoryMessage((
                        speaker: "Broker Vesh",
                        text: "You cooked a fortune, Kestrel. The buoy's got it - nothing left in that flash but slag and static. No box, no buyer, nobody chasing a thing that no longer exists. Take us home. Quiet.",
                    )),
                ],
            ),
            // The BURN terminal overlay: a beat after the burn line
            // (`burn_said` one-shot). Victory + a DISTINCT no-fight message; no
            // NextScenario (this is the last chapter, no chain), no
            // StoryMessage beside the Outcome.
            (
                name: OnUpdate,
                filters: [
                    Expression((Equal(
                        Term(Factor(Name("choice"))),
                        Term(Factor(Literal(Number(2.0)))),
                    ))),
                    Expression((Equal(
                        Term(Factor(Name("burn_said"))),
                        Term(Factor(Literal(Number(0.0)))),
                    ))),
                    Expression((GreaterThan(
                        Term(Factor(Name("burn_gate"))),
                        Term(Factor(Literal(Number(0.0)))),
                    ))),
                    Expression((GreaterThan(
                        Term(Factor(Name("scenario_elapsed"))),
                        Term(Factor(Name("burn_gate"))),
                    ))),
                ],
                actions: [
                    VariableSet((
                        key: "burn_said",
                        expression: Term(Factor(Literal(Number(1.0)))),
                    )),
                    Outcome((
                        outcome: Victory,
                        message: Some("BURNED. The box is slag and nobody's left to chase you - no Auditor, no gunship, no fight. But there's no payday either: the debt still stands, and the Kestrel limps home empty. Clear, and broke."),
                    )),
                ],
            ),
            // --- The SELL ending: the Auditor dies, payday at a price. Only
            // the sell path (choice == 1) reaches a live Auditor, so there is
            // ONE auditor-death handler now. The burn path closes itself above
            // (act -> 3 at the buoy, then the deferred BURN overlay); the old
            // `choice == 2` auditor-death handler was DEAD once the burn path
            // stopped spawning the Auditor and has been removed. ---
            (
                name: OnDestroyed,
                filters: [
                    Entity((
                        id: Some("auditor"),
                    )),
                    Expression((Equal(
                        Term(Factor(Name("act"))),
                        Term(Factor(Literal(Number(2.0)))),
                    ))),
                    Expression((Equal(
                        Term(Factor(Name("choice"))),
                        Term(Factor(Literal(Number(1.0)))),
                    ))),
                ],
                actions: [
                    VariableSet((
                        key: "act",
                        expression: Term(Factor(Literal(Number(3.0)))),
                    )),
                    ObjectiveComplete((
                        id: "obj_auditor",
                    )),
                    Outcome((
                        outcome: Victory,
                        message: Some("SOLD. Paid in full - every ledger line cleared, the debt gone in one transfer. The buyer is silent, the Auditor is scrap, and somewhere a manifest lists a box that never existed. Payday, and the price was a gunship."),
                    )),
                ],
            ),
            // Player death before the ending: Defeat + retry the finale. Only
            // reachable on the SELL path (act == 2 during the Auditor fight):
            // the burn path latches act to 3 at the buoy BEFORE any death
            // window, so this act < 3 gate can never trip after a burn.
            (
                name: OnDestroyed,
                filters: [
                    Entity((
                        id: Some("player_spaceship"),
                    )),
                    Expression((LessThan(
                        Term(Factor(Name("act"))),
                        Term(Factor(Literal(Number(3.0)))),
                    ))),
                ],
                actions: [
                    Outcome((
                        outcome: Defeat,
                        message: Some("The Auditor collects the box, the wreck, and the silence."),
                    )),
                    NextScenario((
                        scenario_id: "ledger_ch4_the_buyer",
                        linger: true,
                    )),
                ],
            ),
        ],
    )),
]
