            // --- The SELL branch (act 1 -> 2): dock the box, the sale calls
            // the hammer down. The AUDITOR ARRIVES (telegraphed): the warning
            // comms line lands first, the gunship spawns far and flies passive
            // behind an 8s engage_delay grace so its approach is readable
            // before it is lethal (matches ch2/ch2b/ch3's telegraph). This is
            // the path that KEEPS the fight - payday at a price. ---
            (
                name: OnEnter,
                filters: [
                    Entity((
                        id: Some("handoff_berth"),
                        other_id: Some("player_spaceship"),
                    )),
                    Expression((Equal(
                        Term(Factor(Name("act"))),
                        Term(Factor(Literal(Number(1.0)))),
                    ))),
                ],
                actions: [
                    VariableSet((
                        key: "choice",
                        expression: Term(Factor(Literal(Number(1.0)))),
                    )),
                    VariableSet((
                        key: "act",
                        expression: Term(Factor(Literal(Number(2.0)))),
                    )),
                    StoryMessage((
                        speaker: "Broker Vesh",
                        text: "Docking clamps on, transferring now - wait. Kestrel, that's a military burn painting you, closing fast. My buyer did NOT send a gunship. You've got maybe ten seconds before it's in range. MOVE.",
