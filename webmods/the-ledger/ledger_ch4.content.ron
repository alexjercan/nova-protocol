                    )),
                    Expression((Equal(
                        Term(Factor(Name("act"))),
                        Term(Factor(Literal(Number(2.0)))),
                    ))),
                    Expression((Equal(
                        Term(Factor(Name("choice"))),
                        Term(Factor(Literal(Number(1.0)))),
                    ))),
                ],
                actions: [
                    VariableSet((
                        key: "act",
                        expression: Term(Factor(Literal(Number(3.0)))),
                    )),
                    ObjectiveComplete((
                        id: "obj_auditor",
                    )),
                    Outcome((
                        outcome: Victory,
                        message: Some("SOLD. Paid in full - every ledger line cleared. The buyer is silent, and somewhere a manifest lists a box that never existed. Try to look surprised when the yard asks how."),
                    )),
                ],
            ),
            (
                name: OnDestroyed,
                filters: [
                    Entity((
                        id: Some("auditor"),
                    )),
                    Expression((Equal(
                        Term(Factor(Name("act"))),
                        Term(Factor(Literal(Number(2.0)))),
                    ))),
                    Expression((Equal(
                        Term(Factor(Name("choice"))),
                        Term(Factor(Literal(Number(2.0)))),
                    ))),
                ],
                actions: [
                    VariableSet((
                        key: "act",
                        expression: Term(Factor(Literal(Number(3.0)))),
                    )),
                    ObjectiveComplete((
                        id: "obj_auditor",
                    )),
                    Outcome((
                        outcome: Victory,
                        message: Some("BURNED. Still broke, still breathing - the debt stands, nobody owns that thing now, and the belt will drink to you. The Kestrel flies a little lighter."),
                    )),
                ],
            ),
            // Player death before the ending: Defeat + retry the finale.
            (
                name: OnDestroyed,
                filters: [
                    Entity((
                        id: Some("player_spaceship"),
                    )),
                    Expression((LessThan(
                        Term(Factor(Name("act"))),
                        Term(Factor(Literal(Number(3.0)))),
                    ))),
                ],
                actions: [
                    Outcome((
                        outcome: Defeat,
                        message: Some("The Auditor collects the box, the wreck, and the silence."),
                    )),
                    NextScenario((
                        scenario_id: "ledger_ch4_the_buyer",
                        linger: true,
                    )),
                ],
            ),
        ],
    )),
]
