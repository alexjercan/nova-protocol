                                // the z-arm tips: at y = +1 above an occupied hull
                                // cube, so each turret's -Y base sits against an
                                // occupied cell (the mount rule the lint enforces).
                                (
                                    id: "turret_zp",
                                    position: (0.0, 1.0, 2.0),
                                    rotation: (0.0, 0.0, 0.0, 1.0),
                                    source: Prototype("better_turret_section"),
                                ),
                                (
                                    id: "turret_zm",
                                    position: (0.0, 1.0, -2.0),
                                    rotation: (0.0, 0.0, 0.0, 1.0),
                                    source: Prototype("better_turret_section"),
                                ),
                                // Two RCS thrusters on the x-arm tips (where the
                                // other two turrets were) - the station-keeping
                                // propulsion budget the controller trims against
                                // gravity to hold position.
                                (
                                    id: "rcs_xp",
                                    position: (2.0, 1.0, 0.0),
                                    rotation: (0.0, 0.0, 0.0, 1.0),
                                    source: Prototype("basic_thruster_section"),
                                ),
                                (
                                    id: "rcs_xm",
                                    position: (-2.0, 1.0, 0.0),
                                    rotation: (0.0, 0.0, 0.0, 1.0),
                                    source: Prototype("basic_thruster_section"),
                                ),
                            ],
                        )),
                    )),
                    // --- Planetoids: three big bodies for cover and scale. Large
                    // radius, invulnerable, some with surface gravity.
                    SpawnScenarioObject((
                        base: (
                            id: "planetoid_1",
                            name: "Planetoid",
                            position: (-160.0, -40.0, -140.0),
                            rotation: (0.0, 0.0, 0.0, 1.0),
                        ),
                        kind: Asteroid((
                            radius: 14.0,
                            texture: "dep://base/textures/asteroid.png",
                            health: 2000.0,
                            impact_sound: Some("dep://base/sounds/impact.wav"),
                            surface_gravity: Some(3.0),
                            invulnerable: true,
                        )),
                    )),
                    SpawnScenarioObject((
                        base: (
                            id: "planetoid_2",
                            name: "Planetoid",
                            position: (150.0, 50.0, -300.0),
                            rotation: (0.0, 0.0, 0.0, 1.0),
                        ),
                        kind: Asteroid((
                            radius: 12.0,
                            texture: "dep://base/textures/asteroid.png",
                            health: 2000.0,
                            impact_sound: Some("dep://base/sounds/impact.wav"),
                            surface_gravity: Some(3.0),
                            invulnerable: true,
                        )),
                    )),
                    SpawnScenarioObject((
                        base: (
                            id: "planetoid_3",
                            name: "Planetoid",
                            position: (0.0, -70.0, -470.0),
                            rotation: (0.0, 0.0, 0.0, 1.0),
                        ),
                        kind: Asteroid((
                            radius: 16.0,
                            texture: "dep://base/textures/asteroid.png",
                            health: 2000.0,
                            impact_sound: Some("dep://base/sounds/impact.wav"),
                            surface_gravity: Some(3.0),
                            invulnerable: true,
                        )),
                    )),
                    // --- Asteroid field: destructible debris scattered through
                    // the arena for cover and torpedo-splash hazards.
                    ScatterObjects((
                        id_prefix: "raid_rock_",
                        count: 34,
                        seed: 5107,
                        region: Ring(
                            inner: 70.0,
                            outer: 260.0,
                            y_min: -70.0,
                            y_max: 60.0,
                        ),
                        template: (
                            base: (
                                id: "raid_rock_",
                                name: "Belt Rock",
                                position: (0.0, 0.0, 0.0),
                                rotation: (0.0, 0.0, 0.0, 1.0),
                            ),
                            kind: Asteroid((
                                impact_sound: Some("dep://base/sounds/impact.wav"),
                                destroy_sound: Some("dep://base/sounds/explosion.wav"),
                                radius: 1.0,
                                texture: "dep://base/textures/asteroid.png",
                                health: 100.0,
                                surface_gravity: None,
                                invulnerable: false,
                                lock_signature: None,
                            )),
                        ),
                        asteroid_radius: Some((1.5, 4.5)),
                    )),
                ],
            ),
            // --- Defender kills: each raider death drops raiders_left by one.
            // Four one-shot handlers (an OnDestroyed fires once per entity).
            (
                name: OnDestroyed,
                filters: [
                    Entity((
                        id: Some("raider_1"),
                    )),
                ],
                actions: [
                    VariableSet((
                        key: "raiders_left",
                        expression: Subtract(
                            Factor(Name("raiders_left")),
                            Term(Factor(Literal(Number(1.0)))),
                        ),
                    )),
                ],
            ),
            (
                name: OnDestroyed,
                filters: [
                    Entity((
                        id: Some("raider_2"),
                    )),
                ],
                actions: [
                    VariableSet((
                        key: "raiders_left",
                        expression: Subtract(
                            Factor(Name("raiders_left")),
                            Term(Factor(Literal(Number(1.0)))),
                        ),
                    )),
                ],
            ),
            (
                name: OnDestroyed,
                filters: [
                    Entity((
                        id: Some("raider_3"),
                    )),
                ],
                actions: [
                    VariableSet((
                        key: "raiders_left",
                        expression: Subtract(
                            Factor(Name("raiders_left")),
                            Term(Factor(Literal(Number(1.0)))),
                        ),
                    )),
                ],
            ),
            (
                name: OnDestroyed,
                filters: [
                    Entity((
                        id: Some("raider_4"),
                    )),
                ],
                actions: [
                    VariableSet((
                        key: "raiders_left",
                        expression: Subtract(
                            Factor(Name("raiders_left")),
                            Term(Factor(Literal(Number(1.0)))),
                        ),
                    )),
                ],
            ),
            // --- The base breaks: stamp base_down and let Vesh call it. One-shot
            // on base_said. Does not itself win - the fighters may still be up.
            (
                name: OnDestroyed,
                filters: [
                    Entity((
                        id: Some("magpie_base"),
                    )),
                    Expression((Equal(
                        Term(Factor(Name("base_said"))),
                        Term(Factor(Literal(Number(0.0)))),
                    ))),
                ],
                actions: [
                    VariableSet((
                        key: "base_down",
                        expression: Term(Factor(Literal(Number(1.0)))),
                    )),
                    VariableSet((
                        key: "base_said",
                        expression: Term(Factor(Literal(Number(1.0)))),
                    )),
                    StoryMessage((
                        speaker: "Broker Vesh",
                        text: "The Nest is coming apart - good shooting, Kestrel. Now finish their fighters and the account is closed.",
                        dwell: Some(6.0),
                    )),
                ],
            ),
            // --- Victory: base down AND all four defenders down. An OnUpdate
            // gate (the count is only known after the kills land), one-shot on
            // win_said, latching act -> 2 in the same frame it declares the win
            // so the Defeat handler (act == 1) can never overwrite it. Terminal:
            // this is the campaign's end, no NextScenario.
            (
                name: OnUpdate,
                filters: [
                    Expression((Equal(
                        Term(Factor(Name("act"))),
                        Term(Factor(Literal(Number(1.0)))),
                    ))),
                    Expression((Equal(
                        Term(Factor(Name("base_down"))),
                        Term(Factor(Literal(Number(1.0)))),
                    ))),
                    Expression((Equal(
                        Term(Factor(Name("raiders_left"))),
                        Term(Factor(Literal(Number(0.0)))),
                    ))),
                    Expression((Equal(
                        Term(Factor(Name("win_said"))),
                        Term(Factor(Literal(Number(0.0)))),
                    ))),
                ],
                actions: [
                    VariableSet((
                        key: "act",
                        expression: Term(Factor(Literal(Number(2.0)))),
                    )),
                    VariableSet((
                        key: "win_said",
                        expression: Term(Factor(Literal(Number(1.0)))),
                    )),
                    ObjectiveComplete((
                        id: "obj_raid",
                    )),
                    Outcome((
                        outcome: Victory,
                        message: Some("The Nest is scrap and the last Magpie fighter is tumbling. The account is closed, Kestrel - the debt cleared, the crew that hunted you burning in the rocks, and a gunship under your hands. That is how The Ledger balances."),
                    )),
                ],
            ),
            // --- Player death before the win: Defeat + retry ch5. Gated act ==
            // 1 and latches act -> 3, mirroring the win latch so the two
            // terminals cannot overwrite each other.
            (
                name: OnDestroyed,
                filters: [
                    Entity((
                        id: Some("player_spaceship"),
                    )),
                    Expression((Equal(
                        Term(Factor(Name("act"))),
                        Term(Factor(Literal(Number(1.0)))),
                    ))),
                ],
                actions: [
                    VariableSet((
                        key: "act",
                        expression: Term(Factor(Literal(Number(3.0)))),
                    )),
                    Outcome((
                        outcome: Defeat,
                        message: Some("The gunship comes apart around you and the Nest's guns go quiet with satisfaction. The Magpies keep the belt - and the account stays open."),
                    )),
                    NextScenario((
                        scenario_id: "ledger_ch5_the_raid",
                        linger: true,
                    )),
                ],
            ),
        ],
    )),
]
