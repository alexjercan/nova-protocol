// The Ledger, chapter 2 of 4, part two: THE HEAVIES. The Magpies' answer
// to losing wave one: two reinforced-hull corvettes burn in from the
// south-west lane - the opposite bearing from wave one, so the arena reads
// differently on the same rocks. Exactly ONE of them carries the better
// turret (Crowbar, the gun ship); Kettle Black is the tank with the mook
// gun. Same arena as ledger_ch2 (part one): player, Dray Mule and the
// invulnerable rock field respawn in the same layout - the act-split is
// the chapter's checkpoint, so dying here retries the heavies only, never
// wave one. Spike: tasks/20260717-111808/SPIKE.md (F1/F2/F3/F4/F6/F7).
//
// Acts: 1 = the fight, 2 = lane clear (victory beat, chains to chapter 3).
// Kill gates use `> N-1`, never `== N`; Defeat handlers gate act < 2.
[
    Scenario((
        id: "ledger_ch2b_the_heavies",
        name: "The Ledger 2: The Heavies",
        description: "The Magpies send their reinforced hulls for the box. Hold the lane. Chapter two of The Ledger, wave two.",
        cubemap: "dep://base/textures/cubemap_alt.png",
        thumbnail: Some("dep://base/textures/asteroid.png"),
        hidden: true,
        events: [
            (
                name: OnStart,
                filters: [],
                actions: [
                    VariableSet((
                        key: "act",
                        expression: Term(Factor(Literal(Number(1.0)))),
                    )),
                    VariableSet((
                        key: "kills",
                        expression: Term(Factor(Literal(Number(0.0)))),
                    )),
                    // One-shot flag for the clock-spaced teach beat below
                    // (seeded: an undefined gate fails closed forever).
                    VariableSet((
                        key: "teach_sent",
                        expression: Term(Factor(Literal(Number(0.0)))),
                    )),
                    StoryMessage((
                        speaker: "Foreman Okono",
                        text: "Two more burns on the scope, south-west lane - reinforced hulls. They really want that box, Kestrel.",
                    )),
                    Objective((
                        id: "obj_ch2b_recap",
                        message: "Ch.2 - The Heavies: break the Magpies' second wave.",
                    )),
                    Objective((
                        id: "obj_escort",
                        message: "The Dray Mule must survive.",
                    )),
                    Objective((
                        id: "obj_wave",
                        message: "Destroy the two reinforced Magpies.",
                    )),
                    SpawnScenarioObject((
                        base: (
                            id: "player_spaceship",
                            name: "Salvage Tug Kestrel",
                            position: (0.0, 0.0, 40.0),
                            rotation: (0.0, 0.0, 0.0, 1.0),
                        ),
                        kind: Spaceship((
                            controller: Player((
                                input_mapping: {
                                    "turret": [
                                        Mouse(Left),
                                        Gamepad(RightTrigger2),
                                    ],
                                },
                                speed_cap: Some(25.0),
                                infinite_ammo: true,
                            )),
                            sections: [
                                (
                                    id: "controller",
                                    position: (0.0, 0.0, 0.0),
                                    rotation: (0.0, 0.0, 0.0, 1.0),
                                    source: Prototype("basic_controller_section"),
                                ),
                                (
                                    id: "hull_front",
                                    position: (0.0, 0.0, 1.0),
                                    rotation: (0.0, 0.0, 0.0, 1.0),
                                    source: Prototype("reinforced_hull_section"),
                                ),
                                (
                                    id: "thruster",
                                    position: (0.0, 0.0, 2.0),
                                    rotation: (0.0, 0.0, 0.0, 1.0),
                                    source: Prototype("basic_thruster_section"),
                                ),
                                (
                                    id: "turret",
                                    position: (0.0, 0.0, -1.0),
                                    rotation: (-0.70710677, 0.0, 0.0, 0.70710677),
                                    source: Prototype("better_turret_section"),
                                ),
                            ],
                        )),
                    )),
                    // The escort, same high station as part one: above
                    // the fight plane, west of the pickup. Wave two comes
                    // from the south-west, so the teach-line matters more
                    // here - drawing the heavies east through the rocks
                    // pulls every stray further from her hull.
                    SpawnScenarioObject((
                        base: (
                            id: "dray_mule",
                            name: "Hauler Dray Mule",
                            position: (-40.0, 85.0, -110.0),
                            rotation: (0.0, 0.0, 0.0, 1.0),
                        ),
                        kind: Spaceship((
                            allegiance: Some(Neutral),
                            controller: AI(()),
                            sections: [
                                (
                                    id: "controller",
                                    position: (0.0, 0.0, 0.0),
                                    rotation: (0.0, 0.0, 0.0, 1.0),
                                    source: Prototype("basic_controller_section"),
                                ),
                                (
                                    id: "hull_front",
                                    position: (0.0, 0.0, 1.0),
                                    rotation: (0.0, 0.0, 0.0, 1.0),
                                    source: Prototype("reinforced_hull_section"),
                                ),
                                (
                                    id: "hull_mid",
                                    position: (0.0, 0.0, 2.0),
                                    rotation: (0.0, 0.0, 0.0, 1.0),
                                    source: Prototype("reinforced_hull_section"),
                                ),
                                (
                                    id: "thruster",
                                    position: (0.0, 0.0, 3.0),
                                    rotation: (0.0, 0.0, 0.0, 1.0),
                                    source: Prototype("basic_thruster_section"),
                                ),
                            ],
                        )),
                    )),
                    // The same rock arc as part one (arena continuity):
                    // invulnerable boulders are the armor, chaff is the
