                                    id: "turret",
                                    position: (0.0, 0.0, -1.0),
                                    rotation: (-0.70710677, 0.0, 0.0, 0.70710677),
                                    source: Prototype("better_turret_section"),
                                ),
                            ],
                        )),
                    )),
                    SpawnScenarioObject((
                        base: (
                            id: "magpie_4",
                            name: "Magpie 'Kettle Black'",
                            position: (-620.0, 30.0, -790.0),
                            rotation: (0.0, 0.0, 0.0, 1.0),
                        ),
                        kind: Spaceship((
                            controller: AI((
                                patrol: [
                                    (-620.0, 30.0, -790.0),
                                    (-140.0, 10.0, -220.0),
                                ],
                                // 700, not 650: the patrol-midpoint anchor
                                // sits 665u from the player spawn, and the
                                // leash sphere must cover the whole arena
                                // (review R1.1) or the heavy yo-yos at the
                                // spawn-side edge.
                                leash: Some(700.0),
                                engage_delay: Some(8.0),
                            )),
                            sections: [
                                (
                                    id: "controller",
                                    position: (0.0, 0.0, 0.0),
                                    rotation: (0.0, 0.0, 0.0, 1.0),
                                    source: Prototype("basic_controller_section"),
                                ),
                                (
                                    id: "hull_front",
                                    position: (0.0, 0.0, 1.0),
                                    rotation: (0.0, 0.0, 0.0, 1.0),
                                    source: Prototype("reinforced_hull_section"),
                                ),
                                (
                                    id: "thruster",
                                    position: (0.0, 0.0, 2.0),
                                    rotation: (0.0, 0.0, 0.0, 1.0),
                                    source: Prototype("basic_thruster_section"),
                                ),
                                (
                                    id: "turret",
                                    position: (0.0, 0.0, -1.0),
                                    rotation: (-0.70710677, 0.0, 0.0, 0.70710677),
                                    source: Prototype("light_turret_section"),
                                ),
                            ],
                        )),
                    )),
                ],
            ),
            // The teach beat, clock-spaced off the opening line (one line per
            // beat - the beat-sheet convention): eight seconds after the
            // contact call, while the arrivals are still inbound.
            (
                name: OnUpdate,
                filters: [
                    Expression((GreaterThan(
                        Term(Factor(Name("scenario_elapsed"))),
                        Term(Factor(Literal(Number(8.0)))),
                    ))),
                    Expression((Equal(
                        Term(Factor(Name("teach_sent"))),
                        Term(Factor(Literal(Number(0.0)))),
                    ))),
                    Expression((Equal(
                        Term(Factor(Name("act"))),
                        Term(Factor(Literal(Number(1.0)))),
                    ))),
                ],
                actions: [
                    VariableSet((
                        key: "teach_sent",
                        expression: Term(Factor(Literal(Number(1.0)))),
                    )),
                    StoryMessage((
                        speaker: "Foreman Okono",
                        text: "Same play as before: they'll come to you, not the Mule. Meet them on the far side of the rocks and make the big one work for every shot.",
                    )),
                ],
            ),
            // --- Heavy kills. ---
            (
                name: OnDestroyed,
                filters: [
                    Entity((
                        id: Some("magpie_3"),
                    )),
                    Expression((Equal(
                        Term(Factor(Name("act"))),
                        Term(Factor(Literal(Number(1.0)))),
                    ))),
                ],
                actions: [
                    VariableSet((
                        key: "kills",
                        expression: Add(Factor(Name("kills")), Term(Factor(Literal(Number(1.0))))),
                    )),
                    StoryMessage((
                        speaker: "Foreman Okono",
                        text: "Crowbar's gun just went quiet. That's the one that mattered.",
                    )),
                ],
            ),
            (
                name: OnDestroyed,
                filters: [
                    Entity((
                        id: Some("magpie_4"),
                    )),
                    Expression((Equal(
                        Term(Factor(Name("act"))),
                        Term(Factor(Literal(Number(1.0)))),
                    ))),
                ],
                actions: [
                    VariableSet((
                        key: "kills",
                        expression: Add(Factor(Name("kills")), Term(Factor(Literal(Number(1.0))))),
                    )),
                    StoryMessage((
                        speaker: "Foreman Okono",
                        text: "Kettle Black's cracked. Hull like that and it still wasn't enough.",
                    )),
                ],
            ),
            // Lane clear -> chapter 3.
            (
                name: OnUpdate,
                filters: [
                    Expression((Equal(
                        Term(Factor(Name("act"))),
                        Term(Factor(Literal(Number(1.0)))),
                    ))),
                    Expression((GreaterThan(
                        Term(Factor(Name("kills"))),
                        Term(Factor(Literal(Number(1.0)))),
                    ))),
                ],
                actions: [
                    VariableSet((
                        key: "act",
                        expression: Term(Factor(Literal(Number(2.0)))),
                    )),
                    ObjectiveComplete((
                        id: "obj_wave",
                    )),
                    ObjectiveComplete((
                        id: "obj_escort",
                    )),
                    Outcome((
                        outcome: Victory,
                        message: Some("The Mule is safe, the Magpies are scrap, and the box is officially trouble. Vesh says she can move it quiet - IF you can reach her yard. Go dark, Kestrel."),
                    )),
                    NextScenario((
                        scenario_id: "ledger_ch3_quiet_channel",
                        linger: true,
                    )),
                ],
            ),
            // Losing the Mule loses the wave, any act before the win.
            (
                name: OnDestroyed,
                filters: [
                    Entity((
                        id: Some("dray_mule"),
                    )),
                    Expression((LessThan(
                        Term(Factor(Name("act"))),
                        Term(Factor(Literal(Number(2.0)))),
                    ))),
                ],
                actions: [
                    Outcome((
                        outcome: Defeat,
                        message: Some("The Dray Mule breaks apart - the box, the quota, the job, all of it gone."),
                    )),
                    NextScenario((
                        scenario_id: "ledger_ch2b_the_heavies",
                        linger: true,
                    )),
                ],
            ),
            (
                name: OnDestroyed,
                filters: [
                    Entity((
                        id: Some("player_spaceship"),
                    )),
                    Expression((LessThan(
                        Term(Factor(Name("act"))),
                        Term(Factor(Literal(Number(2.0)))),
                    ))),
                ],
                actions: [
                    Outcome((
                        outcome: Defeat,
                        message: Some("The Magpies pick the Kestrel clean and tow the box away whistling."),
                    )),
                    NextScenario((
                        scenario_id: "ledger_ch2b_the_heavies",
                        linger: true,
                    )),
                ],
            ),
        ],
    )),
]
