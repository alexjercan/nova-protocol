                            health: 100.0,
                            surface_gravity: None,
                            invulnerable: false,
                            lock_signature: None,
                        )),
                    )),
                    SpawnScenarioObject((
                        base: (
                            id: "chaff_3",
                            name: "Debris",
                            position: (10.0, 30.0, -380.0),
                            rotation: (0.0, 0.0, 0.0, 1.0),
                        ),
                        kind: Asteroid((
                            impact_sound: Some("dep://base/sounds/impact.wav"),
                            destroy_sound: Some("dep://base/sounds/explosion.wav"),
                            radius: 2.5,
                            texture: "dep://base/textures/asteroid.png",
                            health: 100.0,
                            surface_gravity: None,
                            invulnerable: false,
                            lock_signature: None,
                        )),
                    )),
                    // Wave two: the heavies, ~950u out on the SOUTH-WEST
                    // lane (the opposite bearing from wave one - same
                    // arena, different geometry). One better turret in the
                    // whole wave: Crowbar is the gun, Kettle Black is the
                    // tank with the mook gun. Long approach = the breather
                    // after part one's checkpoint.
                    SpawnScenarioObject((
                        base: (
                            id: "magpie_3",
                            name: "Magpie 'Crowbar'",
                            position: (-520.0, -40.0, -720.0),
                            rotation: (0.0, 0.0, 0.0, 1.0),
                        ),
                        kind: Spaceship((
                            controller: AI((
                                patrol: [
                                    (-520.0, -40.0, -720.0),
                                    (-90.0, -10.0, -160.0),
                                ],
                                leash: Some(650.0),
                                engage_delay: Some(8.0),
                            )),
                            sections: [
                                (
                                    id: "controller",
                                    position: (0.0, 0.0, 0.0),
                                    rotation: (0.0, 0.0, 0.0, 1.0),
                                    source: Prototype("basic_controller_section"),
                                ),
                                (
                                    id: "hull_front",
                                    position: (0.0, 0.0, 1.0),
