                    SpawnScenarioObject((
                        base: (
                            id: "cover_east_1",
                            name: "Boulder",
                            position: (150.0, 10.0, -260.0),
                            rotation: (0.0, 0.0, 0.0, 1.0),
                        ),
                        kind: Asteroid((
                            impact_sound: Some("dep://base/sounds/impact.wav"),
