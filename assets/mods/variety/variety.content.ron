// The Variety Pack scenario. Every AUTHORED asset ref here is mod-relative
// (`self://...`): the skybox and the asteroid texture load from THIS mod's
// folder, not from base `assets/`. That is the whole point of the dogfood - a
// scenario whose look is owned by the mod. The `self://` paths are rewritten to
// `mods/variety/...` (shipped) or `mods://variety/...` (downloaded) at merge
// time, so the same content works installed or published.
//
// Sections are base prototypes (this mod depends only on `base`); the textures
// are placeholders (task 20260716-205214 swaps in real art on these paths).
[
    Scenario((
        id: "variety_pack_showcase",
        name: "Variety Pack Showcase",
        description: "A calm showcase rendered from mod-shipped art: a nebula skybox and textured drifting rocks.",
        cubemap: "self://textures/nebula.png",
        events: [
            (
                name: OnStart,
                filters: [],
                actions: [
                    DebugMessage((
                        message: "Variety Pack loaded: the skybox and rocks are assets this mod ships itself.",
                    )),
                    SpawnScenarioObject((
                        base: (
                            id: "player_spaceship",
                            name: "Player Spaceship",
                            position: (0.0, 0.0, 0.0),
                            rotation: (0.0, 0.0, 0.0, 1.0),
                        ),
                        kind: Spaceship((
                            controller: Player((
                                input_mapping: {
                                    "turret": [
                                        Mouse(Left),
                                        Gamepad(RightTrigger2),
                                    ],
                                },
                                speed_cap: Some(25.0),
                                infinite_ammo: true,
                            )),
                            sections: [
                                (
                                    id: "controller",
                                    position: (0.0, 0.0, 0.0),
                                    rotation: (0.0, 0.0, 0.0, 1.0),
                                    source: Prototype("basic_controller_section"),
                                ),
                                (
                                    id: "hull_front",
                                    position: (0.0, 0.0, 1.0),
                                    rotation: (0.0, 0.0, 0.0, 1.0),
                                    source: Prototype("reinforced_hull_section"),
                                ),
                                (
                                    id: "thruster",
                                    position: (0.0, 0.0, 2.0),
                                    rotation: (0.0, 0.0, 0.0, 1.0),
                                    source: Prototype("basic_thruster_section"),
                                ),
                                (
                                    id: "turret",
                                    position: (0.0, 0.0, -1.0),
                                    rotation: (-0.70710677, 0.0, 0.0, 0.70710677),
                                    source: Prototype("better_turret_section"),
                                ),
                            ],
                        )),
                    )),
                    // Two drifting rocks, textured from the mod's own PNG.
                    SpawnScenarioObject((
                        base: (
                            id: "variety_rock_1",
                            name: "Drifting Rock",
                            position: (-12.0, 3.0, -35.0),
                            rotation: (0.0, 0.0, 0.0, 1.0),
                        ),
                        kind: Asteroid((
                            radius: 3.0,
                            texture: "self://textures/rock.png",
                            health: 80.0,
                            surface_gravity: None,
                            invulnerable: false,
                            lock_signature: None,
                        )),
                    )),
                    SpawnScenarioObject((
                        base: (
                            id: "variety_rock_2",
                            name: "Drifting Rock",
                            position: (14.0, -4.0, -50.0),
                            rotation: (0.0, 0.0, 0.0, 1.0),
                        ),
                        kind: Asteroid((
                            radius: 4.0,
                            texture: "self://textures/rock.png",
                            health: 120.0,
                            surface_gravity: None,
                            invulnerable: false,
                            lock_signature: None,
                        )),
                    )),
                    Objective((
                        id: "enjoy_the_view",
                        message: "Take in the view - the skybox and rocks are shipped by the Variety Pack mod itself.",
                    )),
                ],
            ),
        ],
    )),
]
