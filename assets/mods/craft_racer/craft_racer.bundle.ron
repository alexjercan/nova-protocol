// The reconstructed-racer example mod. Self-contained: ships its cut cube
// meshes under gltf/ and references them with self://.
(
    content: ["craft_racer.content.ron"],
    resources: [
        "gltf/cube_i0_j0_k0.glb",
        "gltf/cube_i0_j0_k1.glb",
        "gltf/cube_i0_j0_k2.glb",
        "gltf/cube_i0_j0_km1.glb",
        "gltf/cube_i0_j0_km2.glb",
        "gltf/cube_i0_j1_k0.glb",
        "gltf/cube_i0_j1_k1.glb",
        "gltf/cube_i0_j1_k2.glb",
        "gltf/cube_i0_j1_km1.glb",
        "gltf/cube_i0_j1_km2.glb",
        "gltf/cube_i1_j0_k0.glb",
        "gltf/cube_i1_j0_k1.glb",
        "gltf/cube_i1_j0_k2.glb",
        "gltf/cube_i1_j0_km1.glb",
        "gltf/cube_im1_j0_k0.glb",
        "gltf/cube_im1_j0_k1.glb",
        "gltf/cube_im1_j0_k2.glb",
        "gltf/cube_im1_j0_km1.glb",
    ],
    meta: (
        name: "Craft Racer (reconstructed)",
        description: "The Kenney craft_racer rebuilt from its cut hull cubes.",
        author: "cut-obj-into-hulls.py",
        version: "1.0.0",
        dependencies: ["base"],
    ),
)
