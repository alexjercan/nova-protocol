// The base game's own bundle - the base game is just a mod. `meta` is the mod's
// SELF-DESCRIPTION (the single source of truth for name/description/author/...,
// shown in the Mods menu); `version` stays empty for base because the GAME
// version is authoritative here.
(
    content: [
        "sections/base.content.ron",
        "scenarios/asteroid_field.content.ron",
        "scenarios/broadside.content.ron",
        "scenarios/asteroid_next.content.ron",
        "scenarios/menu_ambience.content.ron",
        "scenarios/menu_waystation.content.ron",
        "scenarios/menu_scrapyard.content.ron",
        "scenarios/shakedown_run.content.ron",
    ],
    // The base game's own art, now shipped UNDER assets/base/ and referenced from
    // base content with `self://` (and by mods with `dep://base/<path>`). Every
    // `self://` ref in base content must name one of these (the content gate
    // enforces completeness; sidecar `.meta` files ride along and are not listed).
    resources: [
        "textures/cubemap.png",
        "textures/cubemap_alt.png",
        "textures/asteroid.png",
        "gltf/hull-01.glb",
        "gltf/turret-yaw-01.glb",
        "gltf/turret-pitch-01.glb",
        "gltf/turret-barrel-01.glb",
        "gltf/torpedo-bay-01.glb",
        "banner.png",
    ],
    meta: (
        name: "Base Game",
        description: "Nova Protocol - the core sections, ships and scenarios.",
        author: "Nova Protocol",
    ),
    // The New Game start. Honored ONLY from the base bundle; the merge warns
    // and ignores it on any other bundle (mods cannot redirect New Game).
    new_game_scenario: Some("shakedown_run"),
)
