[
    Scenario((
        id: "asteroid_next",
        name: "Asteroid Field - Next",
        description: "The next scenario after the asteroid field.",
        cubemap: "self://textures/cubemap.png",
        hidden: true,
        events: [
            (
                // Non-lingering cut (task 20260717-201534): a bare relay with
