{
    "name": "nova-protocol-web",
    "version": "1.0.0",
    "description": "Marketing + content site for Nova Protocol (landing, blog, tutorial, wiki)",
    "license": "MIT",
    "author": "alexjercan",
    "type": "commonjs",
    "scripts": {
        "build": "webpack --config webpack.config.js",
        "serve": "webpack serve --config webpack.config.js",
        "format": "prettier --write \"src/**/*.ts\" \"src/**/*.html\" *.config.js *.js *.mjs package.json tsconfig.json",
        "format:check": "prettier --check \"src/**/*.ts\" \"src/**/*.html\" *.config.js *.js *.mjs package.json tsconfig.json",
        "lint": "eslint \"src/**/*.ts\"",
        "lint:fix": "eslint \"src/**/*.ts\" --fix",
        "ci": "npm run format:check && npm run lint && npm run build"
    },
    "keywords": [],
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@tailwindcss/postcss": "^4.3.2",
        "@types/node": "^26.0.1",
        "autoprefixer": "^10.5.2",
        "copy-webpack-plugin": "^14.0.0",
        "css-loader": "^7.1.4",
        "eslint": "^10.6.0",
        "highlight.js": "^11.11.1",
        "html-webpack-plugin": "^5.6.7",
        "markdown-it": "^14.3.0",
        "markdown-it-anchor": "^9.2.1",
        "mermaid": "^11.16.0",
        "postcss": "^8.5.16",
        "postcss-loader": "^8.2.1",
        "prettier": "^3.9.4",
        "style-loader": "^4.0.0",
        "tailwindcss": "^4.3.2",
        "ts-loader": "^9.6.2",
        "ts-node": "^10.9.2",
        "typescript": "^5.9.2",
        "typescript-eslint": "^8.62.1",
        "webpack": "^5.108.3",
        "webpack-cli": "^7.1.0",
        "webpack-dev-server": "^5.2.5"
    }
}
